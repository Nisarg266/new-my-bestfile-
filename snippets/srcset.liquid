{%- comment -%}
  Generates srcset string for responsive images.
  params: image (Image Object), widths (comma-separated string)
{%- endcomment -%}

{%- liquid
  assign src_widths = widths | default: '375,550,750,1100,1500,1780,2000,3000,3840'
  assign width_list = src_widths | split: ','
  if image != nil
    for w in width_list
      assign w_num = w | plus: 0
      if image.width >= w_num
        echo image | image_url: width: w_num | append: ' ' | append: w | append: 'w'
        unless forloop.last
          echo ','
        endunless
      endif
    endfor
  endif
-%}
