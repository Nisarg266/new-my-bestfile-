{%- comment -%}
  Customer address add/edit form.
  params: address (existing address object or nil for new)
{%- endcomment -%}

{%- liquid
  assign af_obj = customer.new_address
  assign af_id = 'AddAddress'
  if address
    assign af_obj = address
    assign af_id = 'EditAddress_' | append: address.id
  endif
-%}

<div id="{{- af_id -}}" class="address-form account-dashboard__main-inner hidden" data-address-form>
  <div class="account-dashboard__main-head">
    <div class="account-dashboard__breadcrumbs">
      <button class="link link--back" data-form-id="{{- af_id -}}">
        {%- render 'icon', icon_name: 'theme-chevron', class: 'icon icon--rotate-180' -%}
        {{- 'customer.addresses.back_to' | t -}}
      </button>
    </div>
    <h2 class="account-dashboard__main-title h5">
      {%- liquid
        if address
          echo 'customer.addresses.edit_address' | t
        else
          echo 'customer.addresses.add_address' | t
        endif
      -%}
    </h2>
  </div>

  <div class="account-dashboard__body">
    <div class="account-dashboard__col">
      {%- form 'customer_address', af_obj -%}
        {%- if form.errors -%}
          <div class="color-red">{{- form.errors | default_errors -}}</div>
        {%- endif -%}

        <div class="form-row form-row--double">
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'first_name'
              assign af_err = form.errors.translated_fields['first_name'] | capitalize | append: ' ' | append: form.errors.messages['first_name']
              assign af_has_err = true
            endif
            render 'text-input', label: 'theme.form.first_name' | t, placeholder: 'theme.form.first_name_placeholder' | t, id: 'AddressFirstName_' | append: form.id, attr: 'autocomplete="given-name"', name: 'address[first_name]', value: form.first_name, message: af_err, has_error: af_has_err, required: true
          -%}
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'last_name'
              assign af_err = form.errors.translated_fields['last_name'] | capitalize | append: ' ' | append: form.errors.messages['last_name']
              assign af_has_err = true
            endif
            render 'text-input', label: 'theme.form.last_name' | t, placeholder: 'theme.form.last_name_placeholder' | t, id: 'AddressLastName_' | append: form.id, attr: 'autocomplete="family-name"', name: 'address[last_name]', value: form.last_name, message: af_err, has_error: af_has_err, required: true
          -%}
        </div>

        <div class="form-row form-row--double">
          {%- render 'text-input', label: 'customer.addresses.company' | t, placeholder: 'customer.addresses.company_placeholder' | t, id: 'AddressCompany_' | append: form.id, attr: 'autocomplete="organization"', name: 'address[company]', value: form.company -%}
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'address1'
              assign af_err = form.errors.translated_fields['address1'] | capitalize | append: ' ' | append: form.errors.messages['address1']
              assign af_has_err = true
            endif
            render 'text-input', label: 'customer.addresses.address1' | t, placeholder: 'customer.addresses.address1_placeholder' | t, id: 'AddressLine1_' | append: form.id, attr: 'autocomplete="address-line1"', name: 'address[address1]', value: form.address1, message: af_err, has_error: af_has_err, required: true
          -%}
        </div>

        <div class="form-row form-row--double">
          {%- render 'text-input', label: 'customer.addresses.address2' | t, placeholder: 'customer.addresses.address2_placeholder' | t, id: 'AddressLine2_' | append: form.id, attr: 'autocomplete="address-line2"', name: 'address[address2]', value: form.address2 -%}
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'city'
              assign af_err = form.errors.translated_fields['city'] | capitalize | append: ' ' | append: form.errors.messages['city']
              assign af_has_err = true
            endif
            render 'text-input', label: 'customer.addresses.city' | t, placeholder: 'customer.addresses.city_placeholder' | t, id: 'AddressCity_' | append: form.id, attr: 'autocomplete="address-level2"', name: 'address[city]', value: form.city, message: af_err, has_error: af_has_err, required: true
          -%}
        </div>

        <div class="form-row form-row--double">
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'country'
              assign af_err = form.errors.translated_fields['country'] | capitalize | append: ' ' | append: form.errors.messages['country']
              assign af_has_err = true
            endif
            capture af_country_attr
              echo 'data-default="' | append: form.country | append: '"'
              echo 'autocomplete="country"'
              if address
                echo 'data-form-id="' | append: form.id | append: '"'
                echo 'data-address-country-select'
              endif
            endcapture
            render 'select-input', id: 'AddressCountry_' | append: form.id, label: 'customer.addresses.country' | t, name: 'address[country]', options: all_country_option_tags, attr: af_country_attr, custom: true, element: 'customer-country-select', message: af_err, has_error: af_has_err, required: true
          -%}
          <div id="AddressProvinceContainer_{{- form.id -}}" style="display:none;">
            {%- liquid
              capture af_prov_attr
                echo 'data-default="' | append: form.province | append: '"'
                echo 'autocomplete="address-level1"'
              endcapture
              render 'select-input', id: 'AddressProvince_' | append: form.id, label: 'customer.addresses.province' | t, name: 'address[province]', attr: af_prov_attr, custom: true, element: 'customer-country-select', placeholder: 'customer.addresses.province_placeholder' | t
            -%}
          </div>
        </div>

        <div class="form-row form-row--double">
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'zip'
              assign af_err = form.errors.translated_fields['zip'] | capitalize | append: ' ' | append: form.errors.messages['zip']
              assign af_has_err = true
            endif
            capture af_zip_attr
              echo 'autocapitalize="characters"'
              echo 'autocomplete="postal-code"'
            endcapture
            render 'text-input', label: 'customer.addresses.zip' | t, placeholder: 'customer.addresses.zip_placeholder' | t, id: 'AddressZip_' | append: form.id, attr: af_zip_attr, name: 'address[zip]', value: form.zip, message: af_err, has_error: af_has_err, required: true
          -%}
          {%- liquid
            assign af_err = ''
            assign af_has_err = false
            if form.errors contains 'phone'
              assign af_err = form.errors.translated_fields['phone'] | capitalize | append: ' ' | append: form.errors.messages['phone']
              assign af_has_err = true
            endif
            render 'text-input', label: 'customer.addresses.phone' | t, placeholder: 'customer.addresses.phone_placeholder' | t, id: 'AddressPhone_' | append: form.id, attr: 'autocomplete="tel"', name: 'address[phone]', value: form.phone, type: 'tel', message: af_err, has_error: af_has_err, required: true
          -%}
        </div>

        {%- unless address == customer.default_address -%}
          <div class="form-row">
            <div class="checkbox">
              {{- form.set_as_default_checkbox -}}
              <label for="address_default_address_{{- form.id -}}">{{- 'customer.addresses.set_default' | t -}}</label>
            </div>
          </div>
        {%- endunless -%}

        <div class="form-row">
          <div>
            {%- liquid
              assign af_btn = 'customer.addresses.add_address' | t
              if address
                assign af_btn = 'customer.addresses.update_address' | t
              endif
              render 'button', value: af_btn, type: 'submit', style: 'solid', class: 'button button__update'
            -%}
          </div>
        </div>
      {%- endform -%}
    </div>
  </div>
</div>
