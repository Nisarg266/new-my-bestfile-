{%- liquid
  assign meta_url = canonical_url | default: request.origin
  assign meta_type = 'website'

  if request.page_type == 'product'
    assign meta_type = 'product'
  elsif request.page_type == 'article'
    assign meta_type = 'article'
  elsif request.page_type == 'collection'
    assign meta_type = 'product.group'
  elsif request.page_type == 'password'
    assign meta_url = request.origin
  endif
%}

{%- comment -%}
  ✅ Hardcoded branding text (replace with whatever you want)
{%- endcomment -%}
{%- assign hardcoded_title = "My Best Life™: Science-Driven Health & Beauty Supplements" -%}
{%- assign hardcoded_description = "Shop our premium range of supplements at the best prices, crafted to fuel your body, sharpen your mind, and glow from within. Own your health. Live your best life." -%}

<title>{{ hardcoded_title }} {{ hardcoded_description }}</title>
<meta name="description" content="{{ hardcoded_description }}">

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ meta_url }}">
<meta property="og:title" content="{{ hardcoded_title }}">
<meta property="og:type" content="{{ meta_type }}">
<meta property="og:description" content="{{ hardcoded_description }}">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
{%- elsif settings.favicon != blank -%}
  <meta property="og:image" content="https:{{ settings.favicon | image_url: width: 512 }}">
  <meta property="og:image:secure_url" content="https:{{ settings.favicon | image_url: width: 512 }}">
  <meta property="og:image:width" content="512">
  <meta property="og:image:height" content="512">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="product:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ hardcoded_title }}">
<meta name="twitter:description" content="{{ hardcoded_description }}">
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
{%- elsif settings.favicon != blank -%}
  <meta name="twitter:image" content="https:{{ settings.favicon | image_url: width: 512 }}">
{%- endif -%}
