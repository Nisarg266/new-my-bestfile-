{%- comment -%}
  Quick cart product view (drawer product detail with variant selection).
  params: product
{%- endcomment -%}

<div class="quick-cart-product product">
  <div class="quick-cart-drawer__slider-wrapper">
    <div class="swiper quick-cart-drawer__media-swiper">
      <div class="swiper-wrapper">
        {%- for qc_media in product.media -%}
          {%- render 'highlighted-product-media', media: qc_media, output_type: 'slider-slide', media_index: forloop.index0 -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="product__content">
    <div class="container">
      <div>
        <div class="product__title-wrapper">
          <a href="{{ product.url }}" title="{{ product.title | escape }}" class="h2 product__title button button--text">{{- product.title | escape | default: 'Product title' -}}</a>
          {%- render 'product-badges', product: product -%}
        </div>
        <div class="product__price">{%- render 'price', product: product, use_variant: true -%}</div>
      </div>

      <product-card class="product-card product-card__quick-cart">
        {%- assign qc_variants = product.variants -%}
        {%- assign qc_swatch_opts = settings.swatches_option | split: ',' -%}
        {%- assign qc_current_swatches = '' -%}
        {%- for qc_so in qc_swatch_opts -%}
          {%- assign qc_so_stripped = qc_so | strip -%}
          {%- assign qc_so_vals = product.options_by_name[qc_so_stripped].values | join: ',' -%}
          {%- assign qc_current_swatches = qc_current_swatches | append: qc_so_vals | append: ',' -%}
        {%- endfor -%}
        {%- assign qc_current_swatches = qc_current_swatches | split: ',' -%}

        {%- liquid
          assign qc_var_avail = product.variants | map: 'available'
          assign qc_var_opt1 = product.variants | map: 'option1'
          assign qc_var_opt2 = product.variants | map: 'option2'
          assign qc_var_opt3 = product.variants | map: 'option3'
        -%}

        {% if settings.show_product_groups_on_product_card %}
          {% render 'product-groups', product: product, on: 'page' %}
        {% endif %}

        <div class="product-card__variants">
          <ul class="product-card__variants--list">
            {%- for qc_i in (1..3) -%}
              {%- assign qc_opts = blank -%}
              {%- if qc_i == 1 -%}{%- assign qc_opts = product.options_with_values[0].values -%}
              {%- elsif qc_i == 2 -%}{%- assign qc_opts = product.options_with_values[1].values -%}
              {%- elsif qc_i == 3 -%}{%- assign qc_opts = product.options_with_values[2].values -%}{%- endif -%}
              {%- if qc_opts != blank -%}
                {%- assign qc_opt_json = qc_opts | json -%}
                {%- unless qc_opt_json contains 'Default' -%}
                  <li>
                    {%- if qc_opts.size > 0 -%}
                      <fieldset class="product__variant-options js-product-card-options">
                        <legend>{{ product.options_with_values[forloop.index0].name -}}<span data-selected-variant>{{- product.options_with_values[forloop.index0].selected_value -}}</span></legend>
                        {%- for qc_opt in qc_opts -%}
                          {%- liquid
                            assign qc_disabled = true
                            for qc_o1 in qc_var_opt1
                              case qc_i
                                when 1
                                  if qc_var_opt1[forloop.index0] == qc_opt and qc_var_avail[forloop.index0]
                                    assign qc_disabled = false
                                  endif
                                when 2
                                  if qc_o1 == product.selected_or_first_available_variant.option1 and qc_var_opt2[forloop.index0] == qc_opt and qc_var_avail[forloop.index0]
                                    assign qc_disabled = false
                                  endif
                                when 3
                                  if qc_o1 == product.selected_or_first_available_variant.option1 and qc_var_opt2[forloop.index0] == product.selected_or_first_available_variant.option2 and qc_var_opt3[forloop.index0] == qc_opt and qc_var_avail[forloop.index0]
                                    assign qc_disabled = false
                                  endif
                              endcase
                            endfor
                          -%}
                          {%- liquid
                            assign qc_has_swatch = false
                            if qc_opt.swatch and settings.product_card_swatches_show
                              assign qc_has_swatch = qc_opt | strip | handleize
                            endif
                            assign qc_in_name = product.id | append: '-option[' | append: qc_i | append: ']'
                            assign qc_in_id = product.id | append: '-variant-option-' | append: qc_i | append: '-' | append: forloop.index
                          -%}
                          <div class="button--variant{% if qc_has_swatch %} button--swatch{% if settings.swatches_shape == 'circle' %} button--swatch-rounded{% endif %}{% endif %}" tabindex="0">
                            {%- render 'product-option', id: qc_in_id, name: qc_in_name, value: qc_opt, swatch_value: qc_opt.swatch, class: 'hidden variant-option-radio-input', visually_hidden: true, product: product, option: qc_opts, where: 'quick-cart-product' -%}
                          </div>
                        {%- endfor -%}
                      </fieldset>
                    {%- endif -%}
                  </li>
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
          </ul>
          <script data-product-variants-json type="application/json">{{- qc_variants | json -}}</script>
        </div>

        {%- liquid
          assign qc_preorder = false
          if product.metafields.theme.preorder.value
            assign qc_preorder = true
          endif
        -%}

        {%- form 'product', product, class: 'product-card__add-to-cart--form product__form product__form--inline', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{- product.first_available_variant.id -}}">
          <div class="product-selector__quantity">{%- render 'quantity-input', product: product, hide_label: true -%}</div>
          <button type="submit" class="button button--filled button--uppercase"{% unless product.available %} disabled{% endunless %}>
            <span>{%- if qc_preorder -%}{{- 'product.preorder' | t -}}{%- else -%}{{- 'theme.actions.add_to_cart' | t -}}{%- endif -%}</span>
          </button>
          {% if qc_preorder == false %}{{- form | payment_button -}}{% endif %}
          <div class="product-form__error-message-wrapper" role="alert" hidden>
            <span class="product-form__error-icon">{% render 'icon', icon_name: 'theme-warning' %}</span>
            <span class="product-form__error-message"></span>
          </div>
        {%- endform -%}
      </product-card>
    </div>
  </div>
</div>
