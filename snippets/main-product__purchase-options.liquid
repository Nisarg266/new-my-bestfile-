{%- comment -%}
  Product purchase options (selling plans / subscriptions).
  params: block, product, product_form_id, product_block_class
{%- endcomment -%}

{%- assign po_variant = product.selected_or_first_available_variant | default: product.variants.first -%}

{%- if product.selling_plan_groups.size != 0 and po_variant.selling_plan_allocations.size != 0 and po_variant.available -%}
  <script src="{{- 'purchase-options.js' | asset_url -}}" defer="defer"></script>
  {%- assign po_block_cls = 'product__purchase-options' | append: ' ' | append: product_block_class -%}
  <div class="{{ po_block_cls }}" {{ block.shopify_attributes }}>
    <div id="Product-Purchase-Options-{{- section.id -}}" class="no-js-hidden">
      {%- assign po_group_ids = po_variant.selling_plan_allocations | map: 'selling_plan_group_id' | uniq -%}

      <purchase-options>
        {%- capture po_opts_html -%}
          <option value="one-time" data-id="Product-Purchase-Option-One-Time" {% if po_variant.requires_selling_plan == false and po_variant.selected_selling_plan_allocation == nil %}selected="selected"{% endif %} {% unless po_variant.requires_selling_plan == false %}disabled{% endunless %}>{{- 'product.selling_plan_one_time_purchase' | t -}}</option>
        {%- endcapture -%}

        {%- assign po_plan_selected = false -%}
        {%- assign po_group_selected = false -%}
        {%- for po_group in product.selling_plan_groups -%}
          {%- unless po_group_ids contains po_group.id -%}{%- continue -%}{%- endunless -%}

          {%- capture po_opts_html -%}
            {{- po_opts_html -}}
            {%- liquid
              assign po_is_sel = false
              if po_variant.selected_selling_plan_allocation.selling_plan_group_id == po_group.id
                assign po_is_sel = true
                assign po_group_selected = true
              elsif po_variant.requires_selling_plan and po_variant.selected_selling_plan_allocation == nil and po_group_selected == false
                assign po_is_sel = true
                assign po_group_selected = true
              endif
            -%}
            <option value="{{- po_group.id -}}" data-id="Product-Purchase-Option-{{- po_group.id -}}" {% if po_is_sel %}selected="selected"{% endif %}>{{- po_group.name | escape -}}</option>
          {%- endcapture -%}

          {%- capture po_groups_html -%}
            {{- po_groups_html -}}
            <div class="product__purchase-group-selects {% unless po_is_sel %} is-hidden {% endunless %}" data-id="Product-Purchase-Option-{{- po_group.id -}}">
              {%- for po_grp_opt in po_group.options -%}
                {%- liquid
                  assign po_opt_lbl = 'product.selling_plan_subscription_type' | t
                  assign po_opt_attr = 'data-selling-plan-selector form="' | append: product_form_id | append: '"'
                -%}
                {%- capture po_opt_opts_html -%}
                  <option value="" disabled {% if po_variant.requires_selling_plan == false and po_variant.selected_selling_plan_allocation == nil %}selected="selected"{% endif %}>Select option</option>
                  {%- for po_plan in po_group.selling_plans -%}
                    {%- liquid
                      assign po_plan_sel = false
                      if po_variant.selected_selling_plan_allocation.selling_plan.id == po_plan.id
                        assign po_plan_sel = true
                      elsif po_plan.group_id == po_group.id and forloop.first and po_plan_selected == false and po_variant.requires_selling_plan
                        assign po_plan_sel = true
                        assign po_plan_selected = true
                      endif
                    -%}
                    <option value="{{- po_plan.id -}}" {% if po_plan_sel %}selected="selected"{% endif %}>{{- po_plan.name -}}</option>
                  {%- endfor -%}
                {%- endcapture -%}
                {%- render 'select-input', label: po_opt_lbl, id: 'Product-Selling-Plan-' | append: po_grp_opt.id, name: 'selling_plan', options: po_opt_opts_html, class: 'product__purchase-options', attr: po_opt_attr, custom: true -%}
              {%- endfor -%}
            </div>
          {%- endcapture -%}
        {%- endfor -%}

        {%- render 'select-input', label: 'product.selling_plan_purchase_options' | t, id: 'Product-Purchase-Options', name: 'selling_plan_group', options: po_opts_html, class: 'product__purchase-options', attr: 'data-selling-plan-group-selector', custom: true -%}

        <div class="product__purchase-options-body {% if po_variant.requires_selling_plan == false and po_variant.selected_selling_plan_allocation == nil %} is-hidden{% endif %}" data-selling-plans-wrapper>{{- po_groups_html -}}</div>
      </purchase-options>

      {%- liquid
        assign po_curr_alloc = po_variant.selected_selling_plan_allocation
        if po_curr_alloc == nil and po_variant.requires_selling_plan
          assign po_curr_alloc = po_variant.selling_plan_allocations | first
        endif
      -%}
      <div id="ProductPurchaseInfo-{{- section.id -}}" class="product__purchase--info" data-selling-plan-info>
        {% unless po_curr_alloc == null %}
          {% if block.settings.show_subscription_title %}<p class="product__purchase--info-name">{{ po_curr_alloc.selling_plan.name }}</p>{% endif %}
          {% if po_curr_alloc.per_delivery_price != blank or block.settings.show_subscription_custom_info != blank or shop.subscription_policy != blank and block.settings.show_subscription_policy %}
            <div class="product__purchase--info-subline">
              {% if po_curr_alloc.per_delivery_price != blank %}
                <span class="product__purchase--info-price">
                  {%- liquid
                    assign po_plan_price = po_curr_alloc.per_delivery_price | money
                    echo po_curr_alloc.selling_plan.options.first.value | append: ' '
                    echo 'product.from_price_per_html' | t: price: po_plan_price | append: '.'
                  -%}
                </span>
              {% endif %}
              {% if block.settings.show_subscription_custom_info != blank %}<span class="product__purchase--info-additional">{{- block.settings.show_subscription_custom_info -}}</span>{% endif %}
              {%- if shop.subscription_policy != blank and block.settings.show_subscription_policy -%}
                <menu-drawer class="product__subscription-policy">
                  <details id="Subscription-Policy-drawer" class="drawer__container">
                    <summary class="drawer__button drawer__button--text"><span class="drawer__button-text underlined-link caption caption--small">{{- 'product.view_subscription_policy' | t -}}</span></summary>
                    <div class="drawer__content js-drawer" id="Subscription-Policy-menu-drawer" tabindex="-1">
                      <button class="drawer__button-close button-reset no-js-hidden js-btn-close-drawer" aria-label="{{- 'theme.actions.close' | t -}}" aria-controls="Subscription-Policy-menu-drawer" aria-expanded="false">{%- render 'icon', icon_name: 'theme-arrow' -%}</button>
                      <div class="drawer__row drawer__row--gutter-sm">
                        <h2 class="drawer__title heading-static">{{- shop.subscription_policy.title -}}</h2>
                        <div class="rte">{{- shop.subscription_policy -}}</div>
                      </div>
                    </div>
                  </details>
                </menu-drawer>
              {%- endif -%}
            </div>
          {% endif %}
        {% endunless %}
      </div>
    </div>
  </div>
{%- endif -%}

{%- if product.selling_plan_groups.size > 0 -%}
  <noscript>
    <div class="product__selling-plan">
      {%- capture po_ns_opts -%}
        {%- unless product.requires_selling_plan -%}<option value="">One-time purchase</option>{%- endunless -%}
        {%- for po_ns_group in product.selling_plan_groups -%}
          <optgroup label="{{- po_ns_group.name -}}">
            {%- for po_ns_plan in po_ns_group.selling_plans -%}<option value="{{- po_ns_plan.id -}}"{% if po_ns_plan.selected %} selected{% endif %}>{{- po_ns_plan.options[0].value -}}</option>{%- endfor -%}
          </optgroup>
        {%- endfor -%}
      {%- endcapture -%}
      {%- render 'select-input', id: 'Product-Purchase-Options', name: 'selling_plan', options: po_ns_opts, class: 'product__selling-plan-dropdown' -%}
    </div>
  </noscript>
{%- endif -%}
