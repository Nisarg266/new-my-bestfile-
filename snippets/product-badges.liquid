{%- comment -%}
  Product badges (custom, discount, sold out, preorder).
  params: product, block, show_badges_custom, show_badges_discount
{%- endcomment -%}

{%- liquid
  assign badge_on_pdp = block | default: false
  assign badge_show_custom = show_badges_custom | default: false
  assign badge_show_discount = show_badges_discount | default: false
  assign badge_show_sold = false

  if badge_on_pdp and block.settings.show_badges
    assign badge_show_custom = true
  elsif badge_on_pdp == false and settings.show_product_card_badges
    assign badge_show_custom = true
  endif

  if badge_on_pdp and block.settings.show_badges_discount
    assign badge_show_discount = true
  elsif badge_on_pdp == false and settings.show_product_card_badges_discount
    assign badge_show_discount = true
  endif

  if badge_on_pdp and block.settings.show_badges_sold
    assign badge_show_sold = true
  elsif badge_on_pdp == false and settings.show_product_card_badges_sold
    assign badge_show_sold = true
  endif

  assign all_badges = ''
  if product and product != empty
    # Custom badges from metafield
    assign mf_badges = product.metafields.custom.badges
    if mf_badges != blank
      assign mf_val = mf_badges.value
      if mf_val != blank
        assign badge_count = 0
        for item in mf_val
          assign item_text = item | strip
          if item_text != blank
            assign all_badges = all_badges | append: item_text | append: ','
            assign badge_count = badge_count | plus: 1
          endif
        endfor
        if badge_count == 0
          assign single_text = mf_val | strip
          if single_text != blank
            if single_text contains ','
              assign single_arr = single_text | split: ','
              for item in single_arr
                assign trimmed = item | strip
                if trimmed != blank
                  assign all_badges = all_badges | append: trimmed | append: ','
                endif
              endfor
            else
              assign all_badges = all_badges | append: single_text | append: ','
            endif
          endif
        endif
      endif
    endif

    # Discount badge
    assign badge_prod = product.selected_or_first_available_variant | default: product
    if badge_on_pdp and badge_prod.compare_at_price > badge_prod.price and badge_show_discount
      assign badge_pct = badge_prod.compare_at_price | minus: badge_prod.price | times: 100 | divided_by: badge_prod.compare_at_price
      assign badge_disc_txt = 'product.discount_badge_html' | t: percentage: badge_pct
      assign all_badges = all_badges | append: badge_disc_txt | append: ','
    elsif badge_on_pdp and product.compare_at_price > product.price and badge_show_discount
      assign badge_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
      assign badge_disc_ghost = 'product.discount_badge_html' | t: percentage: badge_pct
      assign all_badges = all_badges | append: badge_disc_ghost | append: ','
    endif

    # Preorder
    if product.metafields.theme.preorder.value
      assign all_badges = all_badges | append: 'product.preorder_badge' | t | append: ','
    endif

    # Tag-based badges
    if badge_show_custom
      for tag in product.tags
        if tag contains 'badge:'
          assign tag_badge = tag | remove: 'badge:' | strip
          assign all_badges = all_badges | append: tag_badge | append: ','
        endif
      endfor
    endif

    # Sold out
    if product.available == false and badge_show_sold
      assign all_badges = all_badges | append: 'product.sold_out' | t | append: ','
    endif
  endif
-%}

{%- if all_badges != '' -%}
  {% style %}
  :root {
    --color-badge-discount-background: {{- settings.product_badge_background_color -}};
    --color-badge-discount-foreground: {{- settings.product_badge_foreground_color -}};
  }
  {% endstyle %}
  <link rel="stylesheet" href="{{- 'component-product-badges.css' | asset_url -}}" media="print" onload="this.media='all'">

  {%- assign badge_list = all_badges | split: ',' -%}
  <span class="product-card__badges">
    {%- for badge in badge_list -%}
      {% capture badge_extra %}{% if badge contains badge_disc_txt %} product-card__badge--discount{% endif %}{% if badge contains badge_disc_ghost %} product-card__badge--discount hidden{% endif %} {% if settings.button_border_radius == "0" %}product-card__badge--square{% else %}product-card__badge--rounded{% endif %}{% endcapture %}
      {%- assign badge_css = 'product-card__badge' | append: badge_extra | strip -%}
      <span class="{{ badge_css }}">{{- badge -}}</span>
    {%- endfor -%}
  </span>
{%- endif -%}
