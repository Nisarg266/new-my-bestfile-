{%- comment -%}
  Product price display (regular, sale, discount badge, unit price).
  params: product, use_variant, price_class
{%- endcomment -%}

{%- liquid
  if use_variant
    assign price_target = product.selected_or_first_available_variant
  else
    assign price_target = product
  endif

  assign price_variant = product.selected_or_first_available_variant

  assign price_compare = price_target.compare_at_price
  assign price_compare_max = price_target.compare_at_price_max
  assign price_compare_min = price_target.compare_at_price_min
  assign price_val = price_target.price | default: 1999
  assign price_val_min = product.price_min
  assign price_val_max = product.price_max
  assign price_available = price_target.available | default: false

  assign money_val = price_val | money
  assign money_min = price_val_min | money
  assign money_max = price_val_max | money
  if settings.show_currency_codes
    assign money_val = price_val | money_with_currency
    assign money_min = price_val_min | money_with_currency
    assign money_max = price_val_max | money_with_currency
  endif

  if price_target == product and product.price_varies == false
    assign price_compare = price_target.compare_at_price_max
  endif
-%}

<div class="price
  id="cart123"
  {%- if price_class %} {{ price_class }}{% endif -%}
  {%- if price_available == false %} price--sold-out {% endif -%}
  {%- if price_compare > price_val %} price--on-sale {% endif -%}
  {%- if product.price_varies == false and product.compare_at_price_varies %} price--no-compare{% endif -%}
">

  <div class="price__container" id="cart123"
    data-label-price-regular="{{ 'product.price_regular' | t }}"
    data-label-price-sale="{{ 'product.price_sale' | t }}"
    data-label-price-from="{{ 'product.price_from' | t }}"
    data-label-price-min="{{ 'product.price_min' | t }}"
    {% if settings.show_currency_codes %}
      data-money-format = "{{ shop.money_with_currency_format }}"
    {% else %}
      data-money-format = "{{ shop.money_format }}"
    {% endif %}
  >
    {%- if price_target -%}
      {%- if price_target == product and product.price_varies -%}
        {%- if price_compare_max > product.price_max or price_compare_min > product.price_min -%}
          <div class="price__sale">
            <div class="price__sale-inner">
              {%- assign pct_off = 0 -%}
              {%- if price_compare > price_val -%}
                {%- assign pct_off = price_compare | minus: price_val | times: 100 | divided_by: price_compare | round -%}
              {%- endif -%}
              <div class="price-wrapper">
                <span class="price-current">{{ price_val | money }}</span>
                {%- if price_compare > price_val -%}
                  <s class="price-compare">{{ price_compare | money }}</s>
                  <span class="price-badge">SAVE {{ pct_off }}%</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="price__regular">
            <span class="visually-hidden">{{- 'product.price_min' | t -}}</span>
            <span>{{- money_min -}}</span>
            <span aria-hidden="true">-</span>
            <span class="visually-hidden">{{- 'product.price_max' | t -}}</span>
            <span>{{- money_max -}}</span>
          </div>
        {%- endif -%}

      {%- elsif price_compare > price_val -%}
        {%- if template.name == 'product' -%}
          <div class="price__sale">
            <div class="price__sale-inner">
              {%- assign pct_off = 0 -%}
              {%- if product.compare_at_price_max > product.price -%}
                {%- assign pct_off = product.compare_at_price_max | minus: product.price | times: 100 | divided_by: product.compare_at_price_max | round -%}
              {%- endif -%}
              <div class="price-wrapper">
                <span class="price-current">₹{{ product.price | money_without_currency }}</span>
                {%- if product.compare_at_price_max > product.price -%}
                  <s class="price-compare">₹{{ product.compare_at_price_max | money_without_currency }}</s>
                  <span class="price-badge">SAVE {{ pct_off }}%</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="price__sale">
            <div class="price__sale-inner">
              {%- assign pct_off = 0 -%}
              {%- if product.compare_at_price_max > product.price -%}
                {%- assign pct_off = product.compare_at_price_max | minus: product.price | times: 100 | divided_by: product.compare_at_price_max | round -%}
              {%- endif -%}
              <div class="price-wrapper">
                <span class="price-current">{{ product.price | money }}</span>
                {%- if product.compare_at_price_max > product.price -%}
                  <s class="price-compare">{{ product.compare_at_price_max | money }}</s>
                  <span class="price-badge">SAVE {{ pct_off }}%</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endif -%}

      {%- else -%}
        <div class="price__regular">
          <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
          <span>{{ money_val }}</span>
        </div>
      {%- endif -%}

      {%- if price_variant.unit_price_measurement -%}
        <div class="product__notice caption caption--small">
          <span class="visually-hidden">{{- 'product.price_unit' | t -}}</span>
          {%- if settings.show_currency_codes -%}{{- price_variant.unit_price | money_with_currency -}}{%- else -%}{{- price_variant.unit_price | money -}}{%- endif -%}
          <span aria-hidden="true">/</span>
          {%- if price_variant.unit_price_measurement.reference_value != 1 -%}{{- price_variant.unit_price_measurement.reference_value -}}{%- endif -%}
          {{- price_variant.unit_price_measurement.reference_unit -}}
        </div>
      {%- endif -%}
    {%- else -%}
      <span>{{- 9999 | money -}}</span>
    {%- endif -%}
  </div>
</div>
