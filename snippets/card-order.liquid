{%- comment -%}
  Order summary card for account dashboard.
  params: order_ref, class, hide_title
{%- endcomment -%}

{%- assign ord_ref = order_ref -%}

<div class="account-card {{ class }}">
  {%- unless hide_title -%}
    <h3 class="account-card__title account-card__last-order h6">{{- 'customer.order.last_order' | t -}}</h3>
  {%- endunless -%}

  <div class="account-card__row">
    <h6 class="account-card__subtitle">{{- 'customer.order.label' | t -}}</h6>
    <p class="account-card__text">{{- ord_ref.name -}}</p>
  </div>
  <div class="account-card__row">
    <h6 class="account-card__subtitle">{{- 'customer.order.date' | t -}}</h6>
    <p class="account-card__text">{{- ord_ref.created_at | date: format: 'short' -}}</p>
  </div>
  <div class="account-card__row">
    <h6 class="account-card__subtitle">{{- 'customer.order.payment_status' | t -}}</h6>
    <p class="account-card__text">{{- ord_ref.financial_status_label -}}</p>
  </div>
  <div class="account-card__row">
    <h6 class="account-card__subtitle">{{- 'customer.order.fulfillment_status' | t -}}</h6>
    <p class="account-card__text">{{- ord_ref.fulfillment_status_label -}}</p>
  </div>
  <div class="account-card__row">
    <h6 class="account-card__subtitle">{{- 'customer.order.total' | t -}}</h6>
    <p class="account-card__text">{{- ord_ref.total_price | money -}}</p>
  </div>

  <div class="account-card__actions">
    {% liquid
      assign ord_btn_val = 'customer.order.view' | t
      render 'button', type: 'link', href: ord_ref.customer_url, value: ord_btn_val, class: 'button button--outlined'
      assign ord_btn_val = nil
    %}
  </div>
</div>
