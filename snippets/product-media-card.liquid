{%- comment -%}
  Product media card (slide, grid, or thumb) for product gallery.
  params: media, card_type, zoom_modal, media_index, modal_id, media_is_active,
          data_group_array, variant_images, featured_media, hide_variants_media,
          image_srcset, media_index_for_image, section_index, thumbs_ratio
{%- endcomment -%}

{%- liquid
  if media_is_active
    assign mc_active = true
  else
    assign mc_active = false
    assign mc_variant_media = product.selected_or_first_available_variant.featured_media.id
    if media.id == mc_variant_media
      assign mc_active = true
    elsif mc_variant_media == blank and media_index == 0
      assign mc_active = true
    endif
    if card_type == 'grid'
      assign mc_active = false
    endif
  endif

  assign mc_group = data_group_array[media_index]
  if mc_group == blank
    if media.id == product.selected_or_first_available_variant.featured_media.id
      assign mc_group = product.selected_or_first_available_variant.options[0]
    endif
  endif
-%}

{%- if card_type == 'slide' or card_type == 'grid' -%}
  <div class="swiper-slide{% if hide_variants_media and variant_images contains featured_media.src %} product__media-item--variant{% endif %}"
    data-media-id="{{- media.id -}}" data-media-type="{{- media.media_type -}}" data-media-group="{{ mc_group }}" data-index="{{- media_index -}}"
    {%- if mc_active %} data-selected{% endif -%}>

    {%- capture mc_render -%}
      {%- case media.media_type -%}
        {%- when 'video' -%}
          {{- media | video_tag: image_size: '600x', autoplay: true, muted: true, loop: true, controls: settings.show_controls_on_product_video -}}
        {%- when 'external_video' -%}
          {% render 'external-video', video: media, video_id: media.external_id, video_type: media.host, controls: settings.show_controls_on_product_video %}
        {%- when 'model' -%}
          {%- if card_type == 'grid' -%}
            {%- render 'image', image: media, section_index: section_index, media_index: media_index_for_image, alt: media.alt -%}
          {%- else -%}
            {{- media | model_viewer_tag -}}
          {% endif %}
        {%- else -%}
          {%- render 'image', image: media, section_index: section_index, media_index: media_index_for_image, alt: media.alt, loading: 'lazy' -%}
      {%- endcase -%}
    {%- endcapture -%}

    <div class="media">
      {%- case zoom_modal -%}
        {%- when 'trigger' -%}
          <div class="media__overlay">
            <div class="media__type--badge main-product__media--feat color-{{ section.settings.color_scheme_gallery }} gradient" title="{{ media.media_type | capitalize }}">
              {%- if media.media_type == 'model' -%}{% render 'icon', icon_name: 'theme-3d-model' %}
              {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}{% render 'icon', icon_name: 'theme-video' %}{%- endif -%}
            </div>
            <div class="product__gallery-opener main-product__media--feat{% if mc_active %} is-active{% endif %} no-js-hidden color-{{ section.settings.color_scheme_gallery }} gradient" data-modal-opener-id="{{- media.media_type | handle -}}-{{- media.id -}}">
              {%- if media.media_type == 'image' -%}
                <a href="{{- media.preview_image | image_url: width: media.preview_image.width -}}" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-image data-pswp-src="{{- media.preview_image | image_url: width: media.preview_image.width -}}" data-pswp-srcset="{{- image_srcset -}}" data-pswp-width="{{- media.preview_image.width -}}" data-pswp-height="{{- media.preview_image.height -}}" target="_blank" {% unless media.position == 1 %}tabindex="-1"{% endunless %}>
                  {% render 'icon', icon_name: 'theme-expand' %}
                  <span class="visually-hidden">{{- 'product.media_open_with_index' | t: index: media_index -}}</span>
                </a>
              {%- elsif media.media_type == 'video' -%}
                <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- media | video_tag: image_size: '2160x', loop: true, autoplay: true, muted: true, controls: settings.show_controls_on_video -}}' target="_blank">
                  {% render 'icon', icon_name: 'theme-expand' %}
                  <span class="visually-hidden">{{- 'product.media_open_with_index' | t: index: media_index -}}</span>
                </a>
              {%- elsif media.media_type == 'external_video' -%}
                {%- capture mc_ext_vid -%}{% render 'external-video', video: media, video_id: media.external_id, video_type: media.host %}{%- endcapture -%}
                <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- mc_ext_vid -}}' target="_blank">
                  {% render 'icon', icon_name: 'theme-expand' %}
                  <span class="visually-hidden">{{- 'product.media_open_with_index' | t: index: media_index -}}</span>
                </a>
              {%- elsif media.media_type == 'model' -%}
                <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- media | model_viewer_tag -}}' target="_blank">
                  {% render 'icon', icon_name: 'theme-expand' %}
                  <span class="visually-hidden">{{- 'product.media_open_with_index' | t: index: media_index -}}</span>
                </a>
              {%- endif -%}
            </div>
          </div>
          {{- mc_render -}}

        {%- when 'click' -%}
          <div class="media__overlay">
            <div class="media__type--badge main-product__media--feat color-{{ section.settings.color_scheme_gallery }} gradient">
              {%- if media.media_type == 'model' -%}{% render 'icon', icon_name: 'theme-3d-model' %}
              {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}{% render 'icon', icon_name: 'theme-video' %}{%- endif -%}
            </div>
          </div>
          {%- if media.media_type == 'image' -%}
            <a href="{{- media.preview_image | image_url: width: media.preview_image.width -}}" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-image data-pswp-src="{{- media.preview_image | image_url: width: media.preview_image.width -}}" data-pswp-srcset="{{- image_srcset -}}" data-pswp-width="{{- media.preview_image.width -}}" data-pswp-height="{{- media.preview_image.height -}}" target="_blank" {% unless media.position == 1 %}tabindex="-1"{% endunless %}>{{- mc_render -}}</a>
          {%- elsif media.media_type == 'video' -%}
            <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- media | video_tag: image_size: '2160x', loop: true, autoplay: true, muted: true, controls: settings.show_controls_on_video -}}' target="_blank">{{- mc_render -}}</a>
          {%- elsif media.media_type == 'external_video' -%}
            {%- capture mc_ext_vid -%}{% render 'external-video', video: media, video_id: media.external_id, video_type: media.host %}{%- endcapture -%}
            <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- mc_ext_vid -}}' target="_blank">{{- mc_render -}}</a>
          {%- elsif media.media_type == 'model' -%}
            <a href="#" class="product__gallery-toggle motion-reduce" type="button" aria-haspopup="dialog" data-media-id="{{- media.id -}}" data-pswp-type="html" data-pswp-html='{{- media | model_viewer_tag -}}' target="_blank">{{- mc_render -}}</a>
          {%- endif -%}

        {%- else -%}
          {{- mc_render -}}
      {%- endcase -%}
    </div>
  </div>

{%- elsif card_type == 'thumbs' -%}
  <div style="height: auto !important" class="swiper-slide{% if thumbs_ratio %} media--{{- thumbs_ratio -}}{% endif %}" data-media-id="{{- media.id -}}" data-media-type="{{- media.media_type -}}" data-index="{{- media_index -}}" {%- if mc_active %} data-selected{% endif -%}>
    <div class="media media--thumb">
      <div class="media__overlay">
        <div class="media__type--badge  main-product__media--feat" title="{{ media.media_type | capitalize }}">
          {%- if media.media_type == 'model' -%}{% render 'icon', icon_name: 'theme-3d-model' %}
          {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}{% render 'icon', icon_name: 'theme-video' %}{%- endif -%}
        </div>
      </div>
      {%- render 'image', image: media.preview_image, section_index: section.index, media_index: media_index_for_image, image_url_width: 128, alt: media.alt | escape -%}
    </div>
  </div>
{%- endif -%}
