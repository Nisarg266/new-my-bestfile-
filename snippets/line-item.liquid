{%- comment -%}
  Cart line item renderer.
  params: line_item, cart_item (false = cart page, true = drawer), max_quantity
{%- endcomment -%}

{%- liquid
  assign li_index = line_item.index | plus: 1
  assign li_is_drawer = cart_item | default: false
-%}

{% comment %} Check inventory policy for max quantity {% endcomment %}
{%- for v in line_item.product.variants -%}
  {%- if v.id == line_item.variant_id -%}
    {%- assign li_inv_policy = v.inventory_policy -%}
  {%- endif -%}
{%- endfor -%}

{%- assign li_max_qty = max_quantity -%}
{%- if li_inv_policy == 'continue' -%}
  {%- assign li_max_qty = 99 -%}
{%- endif -%}

{%- if li_is_drawer != true -%}

<div class="cart-item" id="CartItem-{{- li_index -}}">
  <div class="cart-item__media">
    {%- if line_item.image -%}
      <a href="{{- line_item.url -}}" class="cart-item__link">
        <span class="visually-hidden">{{- line_item.title | escape -}}</span>
        <div class="media">{%- render 'image', image: line_item.image, image_url_width: 550, alt: line_item.image.alt | escape -%}</div>
      </a>
    {%- endif -%}
  </div>

  <div class="cart-item__details">
    <div class="cart-item__content">
      <h3 class="cart-item__title h6 heading-static"><a href="{{- line_item.url -}}" class="full-unstyled-link">{{- line_item.product.title | escape -}}</a></h3>
      <div class="cart-item__price">
        {%- if line_item.variant.compare_at_price > line_item.variant.price -%}
          <div class="cart-item__discounted-prices">
            <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
            <ins class="color-red">{{- line_item.variant.price | money -}}</ins>
            <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
            <del>{{- line_item.variant.compare_at_price | money -}}</del>
          </div>
        {%- else -%}
          {{- line_item.variant.price | money -}}
        {%- endif -%}

        {%- if line_item.variant.available and line_item.unit_price_measurement -%}
          <div>
            <span class="visually-hidden">{{- 'product.price_unit' | t -}}</span>
            {{- line_item.variant.unit_price | money -}}
            <span aria-hidden="true">/</span>
            {%- if line_item.variant.unit_price_measurement.reference_value != 1 -%}{{- line_item.variant.unit_price_measurement.reference_value -}}{%- endif -%}
            {{ line_item.variant.unit_price_measurement.reference_unit }}
          </div>
        {%- endif -%}
      </div>

      {%- if line_item.properties.size != 0 -%}
        <dl>
          {%- for p in line_item.properties -%}
            {%- assign p_first = p.first | slice: 0 -%}
            {%- if p.last != blank and p_first != '_' -%}
              <div><dd>
                {%- if p.last contains '/uploads/' -%}
                  <a href="{{- p.last -}}" class="link" target="_blank">{{- p.last | split: '<span class="option_divider"></span>' | last -}}</a>
                {%- else -%}
                  {{- p.last -}}
                {%- endif -%}
              </dd></div>
            {%- endif -%}
          {%- endfor -%}
        </dl>
      {%- endif -%}

      {%- if line_item.selling_plan_allocation != nil -%}<p class="cart-item__plan">{{- line_item.selling_plan_allocation.selling_plan.name -}}</p>{%- endif -%}
      <p class="cart-item__error color-red" role="alert" data-line-item-error data-line="{{- li_index -}}"></p>
    </div>

    {% assign li_inv_qty = line_item.product.variants | where: 'id', line_item.variant_id %}
    {% assign li_inv_qty = li_inv_qty[0].inventory_quantity %}

    <div class="cart-item__actions">
      <div class="cart-item__actions--top">
        <div class="cart-item__quantity">
          {%- render 'quantity-input', product_ref: line_item.product, value: line_item.quantity, name: 'updates[]', min: 0, max: li_max_qty, index: li_index, hide_label: true -%}
        </div>
        <cart-remove-button id="Remove-{{- li_index -}}" data-index="{{- li_index -}}">
          <a href="{{- line_item.url_to_remove -}}" title="{{- 'cart.remove' | t -}}">{%- render 'icon', icon_name: 'theme-delete' -%}</a>
        </cart-remove-button>
      </div>
      <div class="cart-item__actions--price">
        {% liquid
          assign li_orig_price = line_item.variant.compare_at_price | times: line_item.quantity
          assign li_final_price = line_item.variant.price | times: line_item.quantity
        %}
        {%- if li_orig_price > li_final_price -%}
          <div class="cart-item__discounted-prices cart-item__price">
            <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
            <ins class="color-red">{{- li_final_price | money -}}</ins>
            <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
            <del>{{- li_orig_price | money -}}</del>
          </div>
        {%- elsif line_item.orginal_price != line_item.final_price and line_item.original_line_price != line_item.final_line_price -%}
          <div class="cart-item__discounted-prices cart-item__price">
            <span class="visually-hidden">{{ 'product.price_sale' | t }}</span>
            <ins class="color-red">{{ line_item.final_line_price | money }}</ins>
            <span class="visually-hidden">{{ 'product.price_regular' | t }}</span>
            <del>{{- line_item.original_line_price | money -}}</del>
          </div>
        {%- else -%}
          <span class="cart-item__price">{{- li_final_price | money -}}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- else -%}

<div class="cart-item" id="CartItem-{{- li_index -}}">
  <div class="cart-item__content-area">
    <div class="cart-item__media">
      {%- if line_item.image -%}
        <a href="{{- line_item.url -}}" class="cart-item__link">
          <span class="visually-hidden">{{- line_item.title | escape -}}</span>
          <div class="media">{%- render 'image', image: line_item.image, image_url_width: 550, alt: line_item.image.alt | escape -%}</div>
        </a>
      {%- endif -%}
    </div>
    <div class="cart-item__content">
      <h3 class="cart-item__title h6 heading-static"><a href="{{- line_item.url -}}" class="full-unstyled-link">{{- line_item.product.title | escape -}}</a></h3>

      <div class="cart-item__info">
        <div class="cart-item__price-content desktop-hide">
          <div class="cart-item__price">
            {%- if line_item.variant.compare_at_price > line_item.variant.price -%}
              <div class="cart-item__discounted-prices">
                <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
                <ins class="color-red">{{- line_item.variant.price | money -}}</ins>
                <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
                <del>{{- line_item.variant.compare_at_price | money -}}</del>
              </div>
            {%- else -%}
              {{- line_item.variant.price | money -}}
            {%- endif -%}

            {%- if line_item.variant.available and line_item.unit_price_measurement -%}
              <div>
                <span class="visually-hidden">{{- 'product.price_unit' | t -}}</span>
                {{- line_item.variant.unit_price | money -}}
                <span aria-hidden="true">/</span>
                {%- if line_item.variant.unit_price_measurement.reference_value != 1 -%}{{- line_item.variant.unit_price_measurement.reference_value -}}{%- endif -%}
                {{ line_item.variant.unit_price_measurement.reference_unit }}
              </div>
            {%- endif -%}
          </div>

          {%- if line_item.discounts -%}
            <ul class="cart-item__discounts list-unstyled" role="list" aria-label="{{- 'customer.order.discount' | t -}}">
              {%- for disc in line_item.discounts -%}
                <li>{%- render 'icon', icon_name: 'theme-sale-tag' -%}<span>{{- disc.title | escape -}}</span></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- unless line_item.product.has_only_default_variant -%}
          <dl>
            {%- for opt in line_item.options_with_values -%}
              <dd>{{- opt.value -}}</dd>
              {%- unless forloop.last -%}{{- '<span class="option_divider"></span>' -}}{%- endunless -%}
            {%- endfor -%}
          </dl>
        {%- endunless -%}

        {%- if line_item.properties.size != 0 -%}
          <dl>
            {%- for p in line_item.properties -%}
              {%- assign p_first = p.first | slice: 0 -%}
              {%- if p.last != blank and p_first != '_' -%}
                <div><dd>
                  {%- if p.last contains '/uploads/' -%}
                    <a href="{{- p.last -}}" class="link" target="_blank">{{- p.last | split: '<span class="option_divider"></span>' | last -}}</a>
                  {%- else -%}
                    {{- p.last -}}
                  {%- endif -%}
                </dd></div>
              {%- endif -%}
            {%- endfor -%}
          </dl>
        {%- endif -%}
      </div>
      {%- if line_item.selling_plan_allocation != nil -%}<p class="cart-item__plan">{{- line_item.selling_plan_allocation.selling_plan.name -}}</p>{%- endif -%}
      <p class="cart-item__error color-red" role="alert" data-line-item-error data-line="{{- li_index -}}"></p>
    </div>
  </div>

  <div class="cart-item__price-content small-hide medium-hide">
    <div class="cart-item__price">
      {%- if line_item.variant.compare_at_price > line_item.variant.price -%}
        <div class="cart-item__discounted-prices">
          <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
          <ins class="color-red">{{- line_item.variant.price | money -}}</ins>
          <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
          <del>{{- line_item.variant.compare_at_price | money -}}</del>
        </div>
      {%- else -%}
        {{- line_item.variant.price | money -}}
      {%- endif -%}

      {%- if line_item.variant.available and line_item.unit_price_measurement -%}
        <div>
          <span class="visually-hidden">{{- 'product.price_unit' | t -}}</span>
          {{- line_item.variant.unit_price | money -}}
          <span aria-hidden="true">/</span>
          {%- if line_item.variant.unit_price_measurement.reference_value != 1 -%}{{- line_item.variant.unit_price_measurement.reference_value -}}{%- endif -%}
          {{ line_item.variant.unit_price_measurement.reference_unit }}
        </div>
      {%- endif -%}
    </div>

    {%- if line_item.discounts -%}
      <ul class="cart-item__discounts list-unstyled" role="list" aria-label="{{- 'customer.order.discount' | t -}}">
        {%- for disc in line_item.discounts -%}
          <li>{%- render 'icon', icon_name: 'theme-sale-tag' -%}<span>{{- disc.title | escape -}}</span></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {% assign li_inv_qty = line_item.product.variants | where: 'id', line_item.variant_id %}
  {% assign li_inv_qty = li_inv_qty[0].inventory_quantity %}

  <div class="cart-item__actions">
    <div class="cart-item__quantity">
      {%- render 'quantity-input', product_ref: line_item.product, value: line_item.quantity, name: 'updates[]', min: 0, max: li_max_qty, index: li_index, hide_label: true, cart_item: li_is_drawer -%}
    </div>
    <cart-remove-button id="Remove-{{- li_index -}}" data-index="{{- li_index -}}">
      <a href="{{- line_item.url_to_remove -}}" title="{{- 'cart.remove' | t -}}">
        <span>{{- 'cart.remove' | t -}}</span>
        {%- render 'icon', icon_name: 'theme-delete' -%}
      </a>
    </cart-remove-button>
  </div>

  <div class="cart-item__total-price">
    {% liquid
      assign li_orig_price = line_item.variant.compare_at_price | times: line_item.quantity
      assign li_final_price = line_item.variant.price | times: line_item.quantity
    %}
    {%- if li_orig_price > li_final_price -%}
      <div class="cart-item__discounted-prices cart-item__price">
        <span class="visually-hidden">{{- 'product.price_sale' | t -}}</span>
        <ins class="color-red">{{- li_final_price | money -}}</ins>
        <span class="visually-hidden">{{- 'product.price_regular' | t -}}</span>
        <del>{{- li_orig_price | money -}}</del>
      </div>
    {%- elsif line_item.orginal_price != line_item.final_price and line_item.original_line_price != line_item.final_line_price -%}
      <div class="cart-item__discounted-prices cart-item__price">
        <span class="visually-hidden">{{ 'product.price_sale' | t }}</span>
        <ins class="color-red">{{ line_item.final_line_price | money }}</ins>
        <span class="visually-hidden">{{ 'product.price_regular' | t }}</span>
        <del>{{- line_item.original_line_price | money -}}</del>
      </div>
    {%- else -%}
      <span class="cart-item__price">{{- li_final_price | money -}}</span>
    {%- endif -%}
  </div>
</div>

{%- endif -%}
