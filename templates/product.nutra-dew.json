    "pdp_accordian_Rhg4j3": {
      "type": "pdp-accordian",
      "blocks": {
        "accordion_item_XTkxDh": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Ceramosides™ (Phytoceramides)",
            "answer": "<p><strong>Why It Works</strong><br/>Phytoceramides are ingested, absorbed, and converted into ceramides, which restore the skin barrier, boost hydration, reduce trans-epidermal water loss (TEWL), and protect the skin.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>● Anti-aging Action:</p><p>-18% in wrinkles</p><p>+26% skin elasticity<br/>● Moisturization Action:</p><p>+21% in skin hydration<br/><a href=\"https://onlinelibrary.wiley.com/doi/10.1111/jocd.16130\" target=\"_blank\">Kern C, et al, J <em>Cosmet Dermatol</em>, 2024</a></p><p><a href=\"https://www.mdpi.com/2079-9284/4/4/37\" target=\"_blank\">Bizot V, et al, <em>Cosmetics</em>, 2017</a></p>"
          }
        },
        "accordion_item_Ffe99t": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Hyaluronic Acid",
            "answer": "<p><strong>Why It Works</strong><br/><br/>Hyaluronic Acid (HA) enhances skin hydration by retaining up to 6000x its weight in water, strengthens the skin barrier, stimulates collagen synthesis, provides antioxidant protection, reduces wrinkles, & supports skin regeneration.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>● Wrinkle Depth: Reduced by 18.8%.</p><p>● Skin Elasticity: Increased by 3.8%<br/>● Skin Hydration: Increased by 10.6%</p><p><a href=\"https://www.jle.com/fr/revues/ejd/e-docs/oral_intake_of_a_new_full_spectrum_hyaluronan_improves_skin_profilometry_and_ageing_a_randomized_double_blind_placebo_controlled_clinical_trial_321540/article.phtml?tab=texte\" target=\"_blank\">Michelotti A, et al, <em>Eur J Dermatol</em>, 2021</a></p>"
          }
        },
        "accordion_item_9Be4bb": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Alpha-Lipoic Acid (ALA)",
            "answer": "<p><strong>Why It Works</strong><br/>ALA is quickly absorbed, reaches skin cells easily, and works as a powerful antioxidant and anti-inflammatory - boosting collagen expression and reducing inflammation by blocking harmful signals in the body.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>ALA enhances glutathione synthesis, offering antioxidant and anti-aging effects. </p><p>Acts as an antioxidant, enhancing skin barrier function and protecting against environmental stress, thereby improving hydration. </p><p><a href=\"https://www.jstage.jst.go.jp/article/jnsv/70/6/70_454/_pdf\" target=\"_blank\">Nomura N, et al, <em>J Nutr Sci Vitaminol (Tokyo)</em>,<br/>  2024</a></p><p><a href=\"https://pubmed.ncbi.nlm.nih.gov/20604712/\">Tsuji-Naito K, et al, <em>Connect Tissue Res</em>, 2010</a></p><p> </p>"
          }
        },
        "accordion_item_Xz6E9C": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Omegia®  (Sea Buckthorn Extract)",
            "answer": "<p><strong>Why It Works</strong><br/>OMEGIA® supports skin health by regulating inflammation and oxidative stress through Omega-7, and by promoting hydration, cell regeneration, and barrier repair via Omega-6 (linoleic acid).</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>● Wrinkles reduced by 9%.</p><p>● Skin hydration increased by 49%.</p><p>● Elasticity increased by 26%.</p><p><a href=\"https://www.naturalingredient.org/wp/wp-content/uploads/ART.N__2.pdf\" target=\"_blank\">Yang B, et al, <em>J Appl Cosmetol</em>,<br/>2009</a></p>"
          }
        },
        "accordion_item_EdmXGn": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Rosehip Extract",
            "answer": "<p><strong>Why It Works</strong><br/>Rose hip extract protects collagen, reduces UV-induced inflammation, supports skin barrier and regeneration, and promotes collagen synthesis through its rich content of antioxidants, polyunsaturated fatty acids, and vitamins A, C, and E.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/><strong>Anti-aging:</strong>  Helps delay signs of aging and support cell longevity.</p><p><strong>Anti-inflammatory and Antimicrobial:</strong> Helps soothe skin and protect against microbial damage.</p><p><strong>Moisturizing:</strong> Reduces trans-epidermal water loss (TEWL), improving skin hydration and barrier function.</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC4655903/\" target=\"_blank\">Phetcharat L, et al,<br/><em>Clin Interv Aging</em>, 2015</a></p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC11043540/\">Oargă Porumb DP, et al, <em>Front<br/>Pharmacol</em>, 2024</a></p>"
          }
        }
      },
