    "faq_nutradrew_jXHrUe": {
      "type": "faq-nutradrew",
      "blocks": {
        "faq_MTreHF": {
          "type": "faq",
          "settings": {
            "question": "Who should use NutraDew™?",
            "answer": "NutraDew™ is ideal for adults (20+), especially those experiencing dry skin, flaky patches, premature aging, or winter-related skin dehydration."
          }
        },
        "faq_YDGrCk": {
          "type": "faq",
          "settings": {
            "question": "Is NutraDew™ better than creams or topical moisturizers?",
            "answer": "Yes—while creams hydrate the outer layer, NutraDew™ supports hydration from within at the cellular level, addressing root causes of dryness, especially for those with chronically dry or aging skin."
          }
        },
        "faq_dP3KKg": {
          "type": "faq",
          "settings": {
            "question": "Can NutraDew™ help with anti-aging?",
            "answer": "Absolutely—NutraDew™ includes Omegia® (Omega-7) and Alpha Lipoic Acid, which support collagen integrity, reduce oxidative stress, and help maintain firmness and elasticity."
          }
        },
        "faq_WayP3N": {
          "type": "faq",
