    "section_accordion_faq_aLCgcK": {
      "type": "section--accordion-faq",
      "blocks": {
        "accordion_item_B8Eb3n": {
          "type": "accordion_item",
          "settings": {
            "title": "What is My Best Life<sup>TM </sup>",
            "description": "My Best Life<sup>TM </sup> is a premium health and wellness brand offering science-backed, clean-label nutritional supplements designed to support everyday well-being. We combine modern research with nature’s best ingredients to help you live a healthier, more vibrant life."
          }
        },
        "accordion_item_rNBqW4": {
          "type": "accordion_item",
          "settings": {
            "title": "Who is behind My Best Life<sup>TM </sup> ?",
            "description": "Founded by a doctor with deep experience in healthcare, pharmaceuticals, and nutraceuticals, My Best Life<sup>TM </sup> is backed by a team of medical experts, formulation specialists, and clinical nutritionists dedicated to transparency, integrity, and innovation."
          }
        },
        "accordion_item_yfjU9X": {
          "type": "accordion_item",
          "settings": {
            "title": "What makes My Best Life<sup>TM </sup>supplements different?",
            "description": "Our formulas are made using clinically studied, branded ingredients, with a strong focus on bioavailability and efficacy. We use innovative delivery systems like liposomal and mouth-dissolving formats to ensure optimal absorption and real results."
          }
        },
        "accordion_item_LNteLn": {
          "type": "accordion_item",
          "settings": {
            "title": "Are your supplements scientifically tested?",
            "description": "Yes. All our products are based on published scientific research and formulated in consultation with healthcare professionals. We prioritize evidence-based and clinically validated ingredients."
          }
        },
        "accordion_item_6KtiyB": {
          "type": "accordion_item",
          "settings": {
            "title": "Where are your products manufactured?",
            "description": "All My Best Life<sup>TM </sup> supplements are manufactured in India at a cGMP-certified, FSSC 22000-compliant, HACCP-compliant, Halal-certified and FSSAI-approved facility that meets international quality standards."
          }
        },
        "accordion_item_rC7E3m": {
          "type": "accordion_item",
          "settings": {
            "title": "Are your products vegan or vegetarian?",
            "description": "Our formulations are 100% vegetarian or vegan. Product-specific details are clearly listed on each label for your convenience."
          }
        },
        "accordion_item_YWYN3c": {
          "type": "accordion_item",
          "settings": {
            "title": "Are there any artificial additives in your products?",
            "description": "No. We believe in clean-label supplements — our products are free from artificial sweeteners, preservatives, gluten, and GMOs."
          }
        },
        "accordion_item_ypqiiU": {
          "type": "accordion_item",
          "settings": {
            "title": "Is My Best Life<sup>TM</sup> safe for long-term use?",
            "description": "Yes. Our supplements are designed for regular use and formulated to be safe, effective, and well-tolerated when taken as directed. However, we always recommend consulting your healthcare provider before starting any new supplement, especially if you have pre-existing conditions."
          }
        },
        "accordion_item_zA8ewX": {
          "type": "accordion_item",
          "settings": {
            "title": "How do I know which supplement is right for me?",
            "description": "You can browse our product range based on your specific health goals — such as skin health, women’s health, brain health, or cellular health — or reach out to our customer care team for personalized recommendations."
          }
