{% layout none %}
{%- paginate search.results by 20 -%}
[
{%- for item in search.results -%}
  {
    "type": {{ item.object_type | json }},
    "title": {{ item.title | json }},
    "url": {{ item.url | json }},
    "content": {{ item.content | default: item.excerpt_or_content | strip_html | truncate: 15000, "" | json }},
    "id": {% if item.object_type == 'product' %}{{ item.id | json }}{% else %}null{% endif %},
    "available": {% if item.object_type == 'product' %}{{ item.available | json }}{% else %}null{% endif %}
  }{% unless forloop.last %},{% endunless %}
{%- endfor -%}
]
{%- endpaginate -%}
