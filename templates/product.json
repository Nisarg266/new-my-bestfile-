    "pdp_accordian_Rhg4j3": {
      "type": "pdp-accordian",
      "blocks": {
        "accordion_item_XTkxDh": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "OPITAC™ (L-Glutathione)",
            "answer": "<p><strong>Why It Works</strong><br/>Glutathione lightens skin by inhibiting melanin production via tyrosinase suppression, shifting melanin type, reducing oxidative stress, and enhancing antioxidant recycling; orobuccal absorption improves its bioavailability.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Reduces UV spots and skin melanin index, brightening skin tone.</p><p>· Decreases wrinkles and improves skin elasticity. </p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC5413479/\" target=\"_blank\">Weschawalit S, et al, <em>Clin<br/>Cosmet Investig Dermatol</em>, 2017</a></p><p><a href=\"https://pubmed.ncbi.nlm.nih.gov/30895708/\" target=\"_blank\">Dilokthornsakul W, et al, <em>J Cosmet<br/>Dermatol</em>, 2019</a></p>"
          }
        },
        "accordion_item_Ffe99t": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Grantria™ (Pomegranate Extract)",
            "answer": "<p><strong>Why It Works</strong><br/>Pomegranate Extract supports skin health by reducing oxidative stress (ellagic acid), inhibiting melanin production and inflammation (punicalagins), and enhancing hydration and regeneration (punicic acid); it also boosts collagen synthesis and inhibits MMP-1 (metalloproteinase-1) to reduce wrinkles.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Reduces crow’s feet wrinkles by 48%, offering strong anti-aging benefits.</p><p>· Improves hydration and skin elasticity by boosting collagen production.</p><p>· Enhances skin radiance by 42%, promoting a healthy, luminous glow.</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC11733350/\" target=\"_blank\">Krishnakumar A, et al, <em>Am J<br/>  Transl Res</em>, 2024</a></p><p><a href=\"https://www.jstage.jst.go.jp/article/jnsv/52/5/52_5_383/_pdf/-char/en\" target=\"_blank\">Kasai K, et al, <em>J Nutr Sci<br/>  Vitaminol (Tokyo)</em>, 2006</a></p><p> </p>"
          }
        },
        "accordion_item_9Be4bb": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "N-Acetyl-L-Cysteine (NAC)",
            "answer": "<p><strong>Why It Works</strong><br/>NAC helps the skin by boosting antioxidants, calming inflammation,<br/>speeding up wound healing, and fighting harmful bacteria, keeping the skin healthy and protected.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Improves skin hydration by strengthening the skin barrier.</p><p>· Protects against UV-induced pigmentation and damage.</p><p>· Promotes faster wound healing.</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC10376274/\" target=\"_blank\">Sahasrabudhe SA, et al, <em>Antioxidants<br/>(Basel)</em>, 2023</a></p>"
          }
        },
        "accordion_item_Xz6E9C": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Liposomal Vitamin C",
            "answer": "<p><strong>Why It Works</strong><br/>Vitamin C boosts collagen production, protects against oxidative and UV damage, reduces pigmentation by inhibiting melanin, and strengthens the skin barrier for better hydration and firmness.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Photoprotection.</p><p>· Reduces hyperpigmentation and brightens skin tone.</p><p>· Reduces wrinkles for anti-aging<br/>benefits.</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC5579659/\" target=\"_blank\">Pullar JM, et al, <em>Nutrients</em>, 2017</a></p>"
          }
        },
        "accordion_item_EdmXGn": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Lutemax Skinglo (Lutein 10 mg + Zeaxanthin 2 mg)",
            "answer": "<p><strong>Why It Works</strong><br/>Lutein and zeaxanthin protect skin by filtering blue light, reducing oxidative stress and inflammation, enhancing hydration by supporting hyaluronan synthesis, and boosting photoprotection against UV damage.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Improved overall skin tone and<br/>brightness.</p><p>· Enhanced skin photoprotection</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC5063591/\" target=\"_blank\">Juturu V, et al, <em>Clin Cosmet Investig<br/>Dermatol</em>, 2016</a></p>"
          }
        },
        "accordion_item_bfDFaV": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Vitamin E (Tocotrienol)",
            "answer": "<p><strong>Why It Works</strong><br/>Vitamin E helps keep your skin younger and brighter by fighting damage from the sun and pollution, reducing dark spots, improving skin firmness, and calming redness.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Boosts UV protection </p><p>· Reduces melanin, evens out skin tone.</p><p>· Prevent wrinkles with strong antioxidant effects</p><p><a href=\"https://pmc.ncbi.nlm.nih.gov/articles/PMC9588953/#abstract1\" target=\"_blank\">Ghazali NI, et al, <em>Front<br/>Pharmacol</em>, 2022</a></p>"
          }
        },
        "accordion_item_e349pF": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Vitamin A (Retinyl Palmitate)",
            "answer": "<p><strong>Why It Works</strong><br/>Retinoids, vitamin A derivatives, boost skin health by promoting cell renewal and collagen production, reducing wrinkles, strengthening the skin barrier, and providing antioxidant protection.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>· Protects skin from UV damage and pigmentation </p><p>· Maintains skin elasticity and reduces wrinkles.</p><p><a href=\"https://aacrjournals.org/clincancerres/article/10/6/1875/185481/Safety-and-Efficacy-of-Dose-Intensive-Oral-Vitamin\" target=\"_blank\">Alberts D, et al, <em>Clin<br/>Cancer Res</em>, 2004</a><br/></p><p><a href=\"https://pubmed.ncbi.nlm.nih.gov/17168870/\" target=\"_blank\">Sorg O, et al, <em>J Cosmet Dermatol</em>,<br/>2005</a></p>"
          }
        },
        "accordion_item_dFnn6E": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Vitamin B3 (Niacinamide)",
            "answer": "<p><strong>Why It Works</strong><br/>Vitamin B3 (Niacinamide) boosts DNA repair, strengthens skin barrier, reduces pigmentation, and fights inflammation -improving hydration, skin tone, and protection from UV damage.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>Anti-melanogenic properties: skin lightening effects and reduction of hyperpigmentation. <br/></p><p>Photoprotection: protect the skin against UV pigmentation/damage </p><p><a href=\"https://ijdvl.com/nicotinamide-mechanism-of-action-and-indications-in-dermatology/\" target=\"_blank\"><em>Bains P, et al, Indian J Dermatol Venereol Leprol</em>, 2018</a></p>"
          }
        },
        "accordion_item_48iVjf": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Zinc (as Zinc Bisglycinate)",
            "answer": "<p><strong>Why It Works</strong><br/>Zinc helps protect your skin from sun and pollution damage by fighting harmful free radicals and supports faster wound healing and stronger immunity.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>Photoprotection: protect the skin against UV pigmentation/ damage. </p><p><a href=\"http://www.bbcosme.com.tw/images/pdf/Zinc_IntJournal%20of%20Dermatology.pdf\" target=\"_blank\"> Rostan EF, et al, <em>Int J Dermatol</em>, 2002</a></p>"
          }
        },
        "accordion_item_pNKgCP": {
          "type": "accordion_item",
          "settings": {
            "use_metafield": false,
            "metafield_key": "",
            "question": "Selenium (as Selenomethionine)",
            "answer": "<p><strong>Why It Works</strong><br/>Selenium boosts antioxidant enzymes to protect skin from UV damage, reduces oxidative stress to prevent aging signs like wrinkles, and supports immune responses to promote skin healing.</p>",
            "answer2": "<p><strong>Proven By Science</strong><br/>Photoprotection: protect the skin against UV pigmentation/ damage. <br/></p><p>Skin Anti-aging: reduces wrinkles and loss of skin elasticity. </p><p><a href=\"https://sci-hub.ru/10.1159/000064534\" target=\"_blank\">Greul AK, et al, <em>Skin Pharmacol Appl Skin Physiol</em>, 2002</a></p><p><a href=\"https://www.pharmanord.com/media/Com_pharmanord/A-7175.pdf\" target=\"_blank\">Segger D, et al, <em>J Dermatolog Treat</em>, 2004</a></p>"
          }
        }
      },
