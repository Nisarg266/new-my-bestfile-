{% schema %}
{
  "name": "How to Use Steps",
  "settings": [
    {
  "type": "color",
  "id": "background_color",
  "label": "Section Background Color",
  "default": "#ffffff"
},
   {
      "type": "textarea",
      "id": "heading",
      "label": "Main Title",
      "default": "Real Science. Real Hydration"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h6", "label": "XS" },
        { "value": "h5", "label": "S" },
        { "value": "h4", "label": "M" },
        { "value": "h3", "label": "L" },
        { "value": "h2", "label": "XL" }
      ],
      "default": "h3"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Side Image"
    },
    {
  "type": "url",
  "id": "right_video_url",
  "label": "Video URL (MP4 only)",
},
    {
  "type": "checkbox",
  "id": "autoplay_video",
  "label": "Autoplay video",
  "default": false
},

        {
      "type": "select",
      "id": "spacing_top",
      "label": "t:sections.global.spacing.spacing_top.label",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:sections.global.spacing.spacing_bottom.label",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "0"
    },
            {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
  "type": "range",
  "id": "left_padding",
  "label": "Left padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
{
  "type": "range",
  "id": "right_padding",
  "label": "Right padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "step_desc",
          "label": "Description",
          "default": "1 tablet daily, after breakfast"
        },
        {
          "type": "select",
          "id": "color",
          "label": "Icon Color",
          "default": "green",
          "options": [
            { "value": "green", "label": "Green" },
            { "value": "red", "label": "Red" },
            { "value": "blue", "label": "Blue" }
          ]
        },
        {
        "type": "image_picker",
        "id": "step_icon",
        "label": "Step Icon"
      }
      ]
    }
  ],
  "presets": [
    {
      "name": "How to Use Steps",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<style>

