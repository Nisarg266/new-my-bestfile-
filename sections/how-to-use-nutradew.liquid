</style>

{% if section.blocks.size > 0 %}
  {%- style -%}
    #shopify-section-{{ section.id }} > div {
      padding-block-start: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
      padding-block-end: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
    }
  {%- endstyle -%}
  <section class="how-to-use-container container section-{{ section.id }}-padding" style="background-color: {{ section.settings.background_color }};">


    <div class="how-to-grid">
      <div class="how-to-steps">
    {% if section.settings.heading != blank %}
      <h2 style="" class="heading123">
        {{ section.settings.heading }}
      </h2>
    {% endif %}      
      {% for block in section.blocks %}
          <div class="step-wrapper">
            <div class="step-circle step-{{ block.settings.color }}">
              {% if block.settings.step_icon %}
                <img src="{{ block.settings.step_icon | img_url: 'master' }}" alt="Step Icon">
              {% else %}
                <span>{{ forloop.index }}</span>
              {% endif %}
            </div>

            <div class="step-card">
              <div class="step-title">{{ block.settings.step_number }}</div>
              <div class="step-desc">{{ block.settings.step_desc }}</div>
            </div>
          </div>
        {% endfor %}
      </div>
<div class="how-to-image">
  {% if section.settings.right_image %}
    <img src="{{ section.settings.right_image | img_url: 'master' }}" alt="How to Use Image">
  {% elsif section.settings.right_video_url %}
 <div class="video-wrapper">
  <video 
    {% if section.settings.autoplay_video %}autoplay muted loop playsinline{% endif %} 
    controls
  >
    <source src="{{ section.settings.right_video_url }}" type="video/mp4">
    Your browser does not support the video tag.
  </video>
</div>

  {% else %}
    <div class="image-placeholder"></div>
  {% endif %}
</div>

    </div>
  </section>
{% endif %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.top_padding}}px !important;
    padding-bottom: {{ section.settings.bottom_padding}}px !important;
    padding-left: {{ section.settings.left_padding}}px !important;
    padding-right: {{ section.settings.right_padding}}px !important;
  }
@media (max-width: 769px) {
     .section-{{ section.id }}-padding {
    padding-top: 20px !important;
    padding-bottom: 10px !important;
    padding-left: 20px !important;
    padding-right: 20px !important;
  }
    }

  
{%- endstyle -%}
