{% if section.blocks.size > 0 %}
  {{ 'section-real-science-hydration.css' | asset_url | stylesheet_tag }}
  {%- style -%}
    #shopify-section-{{ section.id }} > div {
      padding-block-start: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
      padding-block-end: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
    }
  {%- endstyle -%}
  <div class="section-real-science {{ section.settings.color_scheme }}">
    <div class="section-container {{ section.settings.section_width }}">
      <h2 class="section__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading }}
      </h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>

      <div class="cards-grid">
        {% assign cards = section.blocks | slice: 0, 3 %}
        {% for block in cards %}
          <div class="step-card">
            <div class="card-image-container">
              <img
                src="{{ block.settings.image | img_url: '480x480' }}"
                alt="{{ block.settings.title }}"
                class="card-image"
              >
              <div class="step-label">
                {{ block.settings.step_label }}
              </div>
            </div>
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>

      <!-- Dots: Only 3 will be generated by JS -->
    </div>
  </div>
{% endif %}

{% schema %}
{

  "name": "Real Science Hydration",
  "tag": "section",
  "class": "section-real-science",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Main Title",
      "default": "Real Science. Real Hydration"
    },
    {
      "type": "inline_richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "How It Works"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "h6", "label": "XS" },
        { "value": "h5", "label": "S" },
        { "value": "h4", "label": "M" },
        { "value": "h3", "label": "L" },
        { "value": "h2", "label": "XL" }
      ],
      "default": "h3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "t:sections.global.spacing.spacing_top.label",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:sections.global.spacing.spacing_bottom.label",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "0"
    }
  ],
  "blocks": [
    {
      "type": "step_card",
      "name": "Step Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "step_label",
          "label": "Step Label",
          "default": "Step 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Phytoceramides repair the skin barrier"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card Description",
          "default": "This is a card"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Real Science Hydration",

    }
  ]
}
{% endschema %}
