        }
      }
      .reviewer-details-inline {
      display: flex;
      align-items: center;
      gap: 4px; /* reduce gap or even use 2px or 0px for overlap */
    }

    .reviewer-name {
      font-weight: 600;
      font-size: 1.5rem;
      margin: 0;
      padding: 0;
      line-height: 1;
      color:#4A5D44;
    }

    .reviewer-stars svg {
      margin: 0;
      padding: 0;
      width: 12px; /* smaller stars if needed */
      height: 12px;
    }
    .testimonial-card {
    background: white;
    border-radius: 50px;
    padding: 1.5rem;

    margin: auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);

    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.custom-swiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      loop: true,
      pagination: {
        el: '.custom-swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        },
      },
    });
  });
</script>
