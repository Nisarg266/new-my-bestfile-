        }

        /* Reviewer details bigger */
        .reviewer-name {
          font-size: 1.5rem;
          font-weight: 700;
        }


        /* Closer stars and reviewer name with bigger stars */
        .reviewer-info {
          gap: 6px;
        }
        .reviewer-stars {
