{%- style -%}
  .contact-with-content-section {
    padding-block-start: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
    padding-block-end: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }
  .contact-with-content-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .contact-with-content-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media screen and (max-width: 768px) {
    .contact-with-content-container {
      grid-template-columns: 1fr;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient contact-with-content-section">
  <div class="container {{ section.settings.section_width }} contact-with-content-container">

    <div class="contact-with-content-content">
      {%- if section.settings.breadcrumbs -%}
        <div class="main-page__breadcrumbs">
          {%- render 'breadcrumbs', alignment: 'center' -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_page_title -%}
        <h2 class="main-page__title h2 {{ section.settings.page_title_alignment }}">{{ page.title }}</h2>
      {%- endif -%}

      <div class="main-page__content rte">
        {{ page.content }}
      </div>

      {%- if section.settings.info_title != blank or section.settings.info_content != blank -%}
        <div class="main-page__foot rte">
          {%- if section.settings.info_title != blank -%}
            <h2 class="main-page__foot-title h4">
              {{ section.settings.info_title }}
            </h2>
          {%- endif -%}

          {%- if section.settings.info_content != blank -%}
            {{ section.settings.info_content }}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div>
      {{ 'form-contact.css' | asset_url | stylesheet_tag }}
      {%- form 'contact', id: 'ContactForm', class: 'contact-form grid' -%}
        {%- if form.posted_successfully? -%}
          <p class="form-contact__message--success h4 col-span-6" tabindex="-1" autofocus>{{ 'contact.success_message' | t }}</p>
        {%- elsif form.errors -%}
          <div class="color-red">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        {% for block in section.blocks %}
          <div class="col-span-{{ block.settings.column_factor }}" {{ block.shopify_attributes }}>
            {% render 'text-input', block: block, form: form, customer: customer %}
          </div>
        {% endfor %}

        <div class="col-span-6">
          {% render 'textarea-input', id: 'ContactForm-body', label: 'contact.message' | t, name: 'contact[message]', placeholder: 'contact.message_placeholder' | t, body: form.body %}
        </div>

        <div class="form-row form-row--actions col-span-6">
          {% render 'button', type: 'submit', style: 'solid', value: 'contact.submit' | t, class: 'button' %}
        </div>
      {%- endform -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_page_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "select",
      "id": "page_title_alignment",
      "label": "Page title alignment",
      "options": [
        { "value": "text-start", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-end", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "inline_richtext",
      "id": "info_title",
      "label": "Info title"
    },
    {
      "type": "richtext",
      "id": "info_content",
      "label": "Info content"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "max-w-page", "label": "Page width" },
        { "value": "max-w-narrower", "label": "Narrow" },
        { "value": "max-w-fluid", "label": "Full width" }
      ],
      "default": "max-w-narrower"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Top spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "2"
    }
  ],
  "blocks": [
    {
      "type": "field",
      "name": "Form Field",
      "settings": [
        {
          "type": "select",
          "id": "column_factor",
          "options": [
            { "value": "6", "label": "Full width" },
            { "value": "3", "label": "Half width" }
          ],
          "default": "6",
          "label": "Column width"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Field label",
          "default": "Label"
        },
        {
          "type": "select",
          "id": "type",
          "label": "Field type",
          "options": [
            { "value": "text", "label": "Text" },
            { "value": "email", "label": "Email" },
            { "value": "tel", "label": "Phone" }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Placeholder"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": false
        }
      ]
    }
  ]
}
{% endschema %}
