      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}
<script>
document.addEventListener('DOMContentLoaded', function () {
  var navItems = Array.prototype.slice.call(document.querySelectorAll('.js-nav-item.has-dropdown'));
  if (!navItems.length) return;

  var closeDelay = 200; // ms - how long to keep it open after mouse leaves; tune if needed

  navItems.forEach(function(item){
    var closeTimer = null;

    function openImmediate() {
      clearTimeout(closeTimer);
      item.classList.add('is-open');
      var l = item.querySelector('.header__nav-link');
      if (l) l.setAttribute('aria-expanded', 'true');
    }
    function scheduleClose() {
      clearTimeout(closeTimer);
      closeTimer = setTimeout(function(){
        item.classList.remove('is-open');
        var l = item.querySelector('.header__nav-link');
        if (l) l.setAttribute('aria-expanded', 'false');
      }, closeDelay);
    }

    // When pointer enters either the item or its dropdown, open immediately and cancel any close
    item.addEventListener('mouseenter', openImmediate);
    item.addEventListener('focusin', openImmediate); // accessibility

    // When pointer leaves the item (including its dropdown), schedule close
    item.addEventListener('mouseleave', scheduleClose);
    item.addEventListener('focusout', scheduleClose);

    // Also keep open if user enters inner dropdown directly (helps in some markup)
    var dropdown = item.querySelector('.header__nav-dropdown');
    if (dropdown) {
      dropdown.addEventListener('mouseenter', openImmediate);
      dropdown.addEventListener('mouseleave', scheduleClose);
    }
  });
});
</script>

