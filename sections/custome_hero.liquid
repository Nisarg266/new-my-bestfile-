<section
  class="custom-hero-section"
  style="
    height: {{ section.settings.hero_height | append: 'vh' }};
    background-color: {{ section.settings.bg_color }};
    position: relative;
    overflow: hidden;
  "
>
  {% if section.settings.use_video %}
    {% if section.settings.video_url != blank %}
      <video
        autoplay
        muted
        loop
        playsinline
        style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 0;"
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
  {% elsif section.settings.image != blank %}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="Hero background"
      style="width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; z-index: 0;"
    />
  {% endif %}

  <div class="custom-hero-content" style="position: relative; z-index: 1; text-align: center; color: white; padding: 2rem;">
    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p>{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.button_text != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="button" style="margin-top: 1rem; display: inline-block; background: white; color: #2a2a2a; padding: 0.75rem 1.5rem; border-radius: 4px;">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Custom Hero Banner",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "hero_height",
      "label": "Section Height (vh)",
      "min": 50,
      "max": 100,
      "step": 10,
      "default": 100
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2A2A2A"
    },
    {
      "type": "checkbox",
      "id": "use_video",
      "label": "Use video instead of image",
      "default": false
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL (.mp4)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Check out our latest products"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}
