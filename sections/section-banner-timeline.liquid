          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "t:sections.global.spacing.spacing_bottom.label",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
  "type": "color",
  "id": "overlay_color",
  "label": "Overlay Color",
  "default": "#2A2A2A"
},
{
  "type": "range",
  "id": "overlay_opacity",
  "label": "Overlay Opacity (0 = transparent, 1 = solid)",
  "min": 0,
  "max": 1,
  "step": 0.1,
  "default": 0.6
}
    
  ],
  "blocks": [
    {
      "type": "timeline_step",
      "name": "Timeline Step",
      "settings": [
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Step One"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "This is the description for the first step of the timeline."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner With Timeline",
      "category": "Custom"
    }
  ]
}
