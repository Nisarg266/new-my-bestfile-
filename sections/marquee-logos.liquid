{% schema %}
{
  "name": "Marquee Logos",
  "settings": [
  {
    "type": "color",
    "id": "background_color",
    "label": "Background color",
    "default": "#ffffff"
  },
  {
    "type": "range",
    "id": "logo_size",
    "label": "Logo Height (px)",
    "min": 20,
    "max": 100,
    "step": 1,
    "default": 40
  },
  {
    "type": "number",
    "id": "speed",
    "label": "Marquee Speed (seconds)",
    "default": 20
  },
  {
    "type": "range",
    "id": "padding_top",
    "label": "Padding Top (px)",
    "min": 0,
    "max": 100,
    "step": 1,
    "default": 16
  },
  {
    "type": "range",
    "id": "padding_bottom",
    "label": "Padding Bottom (px)",
    "min": 0,
    "max": 100,
    "step": 1,
    "default": 16
  },
  {
    "type": "color",
    "id": "font_color",
    "label": "Text Color",
    "default": "#333333"
  }
  ],
  "blocks": [
    {
      "type": "logo_pair",
      "name": "Logo + Text Pair",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_img",
          "label": "Upload Logo"
        },
       {
  "type": "richtext",
  "id": "logo_text",
  "label": "Logo Text",
  "default": "<p>Your Brand</p>"
}
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Marquee Logos",
      "category": "Custom"
    }
  ]
}
{% endschema %}


<style>
.marquee-wrapper {
  overflow: hidden;
  position: relative;
  background-color: {{ section.settings.background_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.marquee-track {
  display: flex;
  width: max-content;
  animation: scroll-left {{ section.settings.speed }}s linear infinite;
  align-items: center;
}

@keyframes scroll-left {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

.logo-text-pair {
  display: inline-flex;
  align-items: center;
  gap: 1rem;
  margin: 0 2rem;
  white-space: nowrap;
  flex-shrink: 0;
}

.logo-text-pair img {
  height: {{ section.settings.logo_size }}px;
  width: auto;
  display: block;
}

.marquee-text {
  font-size: {{ section.settings.logo_size }}px;
  line-height: 1;
  font-weight: 500;
  color: {{ section.settings.font_color }};
  white-space: nowrap;
}
</style>

<div class="marquee-wrapper">
  <div class="marquee-track">
    {% assign repeat_count = 20 %}
    {% for i in (1..repeat_count) %}
      {% for block in section.blocks %}
        <div class="logo-text-pair">
          {% if block.settings.logo_img %}
            <img src="{{ block.settings.logo_img | image_url: width: 300 }}" alt="logo" loading="lazy" />
          {% endif %}
<div class="marquee-text">{{ block.settings.logo_text | rich_text }}</div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>
  