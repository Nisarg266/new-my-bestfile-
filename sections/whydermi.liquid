{% schema %}
{
  "name": "Unique Modern Lifestyle",
  "tag": "section",
  "class": "section-unique-modern-lifestyle",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Main Title",
      "default": "Real Benefits. Real Results."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Top Spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Bottom Spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "0"
    },
    {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "left_padding",
      "label": "Left padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "right_padding",
      "label": "Right padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "pagination",
      "label": "Pagination",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "showslider_mobile",
      "label": "Enable Slider on Mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Slides Per View (Mobile)",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 2.2
    }
  ],
  "blocks": [
    {
      "type": "unique_lifestyle_card",
      "name": "Lifestyle Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Heading",
          "default": "Card Heading"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Card Subheading",
          "default": "Short description goes here."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Unique Modern Lifestyle"
    }
  ]
}
{% endschema %}

{% style %}
.section-unique-{{ section.id }}-padding {
  padding-top: {{ section.settings.top_padding | times: 0.75 | round: 0 }}px;
  padding-bottom: {{ section.settings.bottom_padding | times: 0.75 | round: 0 }}px;
  padding-left: {{ section.settings.left_padding | times: 0.75 | round: 0 }}px;
  padding-right: {{ section.settings.right_padding | times: 0.75 | round: 0 }}px;
  background-color: {{ section.settings.background_color }};
}

@media screen and (min-width: 750px) {
  .section-unique-{{ section.id }}-padding {
    padding-top: {{ section.settings.top_padding }}px;
    padding-bottom: {{ section.settings.bottom_padding }}px;
    padding-left: {{ section.settings.left_padding }}px;
    padding-right: {{ section.settings.right_padding }}px;
  }
}
{% endstyle %}

<div class="section-unique-modern-lifestyle {{ section.settings.color_scheme }} section-unique-{{ section.id }}-padding">
  <div class="unique-section-container container">
    <h2 class="unique-section__heading">
      {{ section.settings.heading }}
    </h2>

    <div class="unique-cards-wrapper unique-modern-slider-{{ section.id }}">
      <div class="unique-moderncards">
        {% for block in section.blocks %}
          <div class="unique-lifestyle-card">
            <div class="unique-modernimagecontainer">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | img_url: '280x280' }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <h3 class="unique-card-title">{{ block.settings.title }}</h3>
            <p class="unique-card-subtitle">{{ block.settings.subtitle }}</p>
          </div>
        {% endfor %}
      </div>
      <div class="unique-modernscrolldots">
        {% for block in section.blocks %}
          <span {% if forloop.first %}class="active"{% endif %}></span>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% if section.settings.showslider_mobile %}
<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.querySelector('.unique-modern-slider-{{ section.id }}');
  const cardsContainer = container.querySelector('.unique-moderncards');
  const dots = container.querySelectorAll('.unique-modernscrolldots span');
  const cards = container.querySelectorAll('.unique-lifestyle-card');

  if (container && window.innerWidth <= 768) {
    let currentIndex = 0;
    const totalCards = cards.length;

    function updateActiveCard(index) {
      cards.forEach((card, i) => {
        card.style.display = i === index ? 'block' : 'none';
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });

      currentIndex = index;
    }

    updateActiveCard(0);

    let startX = 0;
    let endX = 0;

    cardsContainer.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
    });

    cardsContainer.addEventListener('touchend', (e) => {
      endX = e.changedTouches[0].clientX;
      handleSwipe();
    });

    function handleSwipe() {
      const swipeThreshold = 50;
      const diff = startX - endX;

      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0 && currentIndex < totalCards - 1) {
          updateActiveCard(currentIndex + 1);
        } else if (diff < 0 && currentIndex > 0) {
          updateActiveCard(currentIndex - 1);
        }
      }
    }

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        updateActiveCard(index);
      });
    });
  }
});
</script>
{% endif %}

<style>
.section-unique-modern-lifestyle {
  text-align: center;
 
}

.unique-section-container {
  max-width: 1600px;
  margin: 0 auto;
  width: 100%;
}

.unique-section__heading {
    font-size: clamp(28px, 5vw, 50px) !important;
  font-weight: bold;
  margin-bottom: 30px;
  color: #b4975a;
  text-transform:uppercase;
}

.unique-cards-wrapper {
  position: relative;
}

.unique-moderncards {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 1rem;
}

.unique-moderncards::-webkit-scrollbar {
  display: none;
}

.unique-lifestyle-card {
        max-width: 30.33%;
  flex: 0 0 100%;
  scroll-snap-align: start;
  border-radius: 8px;
  text-align: center;
  transition: transform 0.3s ease;
}

.unique-lifestyle-card:hover {
  transform: translateY(-5px);
}

.unique-modernimagecontainer img {
  width: 100%;
  height: 100%;
  max-height: 100%;
  max-width: 100%;
  object-fit: cover;
border-radius: 13px;
}

.unique-modernscrolldots {
  display: flex;
  justify-content: center;
  margin-top: 12px;
  gap: 6px;
}

.unique-modernscrolldots span {
  width: 8px;
  height: 8px;
  background-color: #ccc;
  border-radius: 50%;
  display: inline-block;
}

.unique-modernscrolldots span.active {
  background-color: #333;
}

.unique-card-title {
  margin-top: 8px;
    text-align: left;

}

.unique-card-subtitle {
  font-size: 25px !important;
    text-align: left;

  color: #666;
  margin-top: 4px;
  line-height: 1.4;
}

/* Desktop layout */
@media (min-width: 1024px) {
  .unique-moderncards {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    overflow: unset;
  }

  .unique-lifestyle-card {
    flex: 0 0 calc((100% - 4rem) / 3);
    scroll-snap-align: unset;
  }

  .unique-modernscrolldots {
    display: none;
  }
}
@media (max-width: 768px) {
  .unique-card-subtitle{
    font-size:18px !important;
  }
  .unique-card-title {
    font-size:23px;
  }
   .unique-lifestyle-card {
    max-width: 100%;
  }
.section-unique-modern-lifestyle {
  text-align: center;
  padding: 10px;
}
}
</style>
