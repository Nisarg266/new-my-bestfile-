{% schema %}
{
  "name": "Accordion",
  "settings": [

      {
            "type": "text",
            "id": "section_id",
            "label": "Section ID"

        },
    {
        "type": "richtext",
      "id": "heading",
    "default": "<p>Default Heading</p>",
          "label": "Heading"
    },
      {
        "type": "richtext",
      "id": "sub-heading",
    "default": "<p>Default Heading</p>",
          "label": "Heading"
    },
        {
            "type": "richtext",
            "id": "short_description",
            "label": "Text"
        },
   {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
{
  "type": "select",
  "id": "accordion-position",
  "label": "Accordion Position",
  "options": [
    {
      "value": "accordion-left",
      "label": "Left"
    },
    {
      "value": "accordion-right",
      "label": "Right"
    }

  ],
  "default": "accordion-left"
},

            {
          "type": "checkbox",
          "id": "show_button_view",
          "label": "Show Button",
          "default": true
        },
        {
          "type": "text",
          "id": "button_label_view",
          "label": "Button Label",
          "default": "View All"
        },
        {
          "type": "url",
          "id": "button_link_view",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "pre_button_description",
          "label": "Pre Button",
          "default": "Still have questions?"
        },

     {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
  "type": "range",
  "id": "left_padding",
  "label": "Left padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
{
  "type": "range",
  "id": "right_padding",
  "label": "Right padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},

    {
  "type": "image_picker",
  "id": "image-bg",
  "label": "Image"
},
       {
        "type": "range",
        "id": "padding_top_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding top mobile",
        "default": 0
      },
      {
        "type": "range",
        "id": "padding_bottom_mobile",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "Padding bottom mobile",
        "default": 0
      },

  ],
  "blocks": [
    {
      "type": "accordion_item",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "textarea",
          "id": "title",
          "label": "Question",
          "default": "This is a question"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Answer",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Accordion",
      "blocks": [
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        },
        {
          "type": "accordion_item"
        }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.top_padding | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.bottom_padding | times: 0.75 | round: 0 }}px;
    padding-left: {{ section.settings.left_padding | times: 0.75 | round: 0 }}px;
    padding-right: {{ section.settings.right_padding | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.top_padding }}px;
      padding-bottom: {{ section.settings.bottom_padding }}px;
      padding-left: {{ section.settings.left_padding }}px;
      padding-right: {{ section.settings.right_padding }}px;
    }
  }
{%- endstyle -%}

<section class="section--accordion-faq container">
  <div
    class="accordion-faq--container page-container section-{{ section.id }}-padding "
  >
    <div
      class="accordion-faq--content  {{ section.settings.accordion-position }}"
    >
      <div class="gt-faq-box">
        <div class="gt-faq-image-wrapper">
          <img src="{{ section.settings.image-bg | img_url: 'master' }}" alt="Help Image" class="gt-faq-image">
        </div>

        <div class="gt-faq-content">
          <div class="gt-faq-description {{ section.settings.text-color }}">
            {{ section.settings.short_description }}
            <p class="gt-faq-pre-desc">{{ section.settings.pre_button_description }}</p>
          </div>

          {% if section.settings.show_button_view %}
            <div class="gt-faq-cta">
              <a href="{{ section.settings.button_link_view }}" class="gt-faq-button">
                {{ section.settings.button_label_view }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="accordion-faq--column" animation-trigger>
        <div class="gt-faq-sub-heading">{{ section.settings['sub-heading'] }}</div>

        <div class="gt-faq-title">{{ section.settings.heading }}</div>

        <div class="accordion" animation-child>
          {% for block in section.blocks %}
            <div class="accordion-item{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
              <div class="accordion-question">
                <h3>{{ block.settings.title }}</h3>
                <span class="accordion-icon">
                  <svg
                    class="plus"
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 14 14"
                    fill="none"
                  >
                    <path d="M0 7H14" stroke="#fff" stroke-width="1.5"/>
                    <path d="M7 14L7 0" stroke="#fff" stroke-width="1.5"/>
                  </svg>

                  <svg
                    class="minus"
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="2"
                    viewBox="0 0 14 2"
                    fill="none"
                  >
                    <path d="M0 1H14" stroke="#F5F5F5" stroke-width="1.5"/>
                  </svg>
                </span>
              </div>
              <div class="accordion-answer">
                <p>{{ block.settings.description }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>
