      transition: max-height .4s ease;
      max-width: 100%;
      font-size: 18px;
      color: #2A2A2A;
  }
    .section--accordion-faq .accordion-question .accordion-icon {
      height: 30px;
      width: 30px;
      min-width: 28px;
      border-radius: 6px;
      display: flex;
