     }

     .section--accordion-faq .accordion {
       width: 100%;
       margin: 0 auto;
       color: #fff;
     }
  .section--accordion-faq .accordion-item {
      cursor: pointer;
      user-select: none;
  }
  .section--accordion-faq .accordion-question {
