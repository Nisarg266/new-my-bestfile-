{% schema %}
{
  "name": "Dual Highlight Cards",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Section Background color",
      "default": "#FFF5EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Section Text color",
      "default": "#2A2A2A"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Highlight Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Read More Button Text",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Read More Button Link"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card Background Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "card_text_color",
          "label": "Card Text Color",
          "default": "#2A2A2A"
        },
        {
          "type": "color",
          "id": "button_color",
          "label": "Button Color",
          "default": "#b6985a"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dual Highlight Cards",
      "category": "Custom"
    }
  ]
}
{% endschema %}

{% style %}
     .dual-cards-section {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: 40px 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
  }

  .highlight-card {
    background: #fff;
    border-radius: 16px;
    padding: 20px;
    flex: 1 1 300px;
    max-width: 500px;
    text-align: left;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.05);
    display: flex;
    flex-direction: column;
    position: relative; /* To position the image absolutely inside the card */
  }

  .highlight-card h3 {
    margin-bottom: 10px;
  }

  .highlight-card p {
    flex-grow: 1; /* Ensure the paragraph takes remaining space and pushes the image down */
  }

  .highlight-card img {
    position:relative; /* Absolutely position the image within the card */
    bottom: 20px; /* Keep the image at the bottom */
    right: 20px; /* Align the image to the right */
    max-width: 100px; /* Set a fixed width for the image */
    max-height: 100px; /* Set a fixed height for the image */
    display: block;
  }

  .highlight-card a {
    display: inline-block;
    margin-top: 10px;
    color: #b6985a;
    font-weight: bold;
  }

  .image-wrapper {
    display: flex;
    justify-content: flex-end; /* Keeps the image aligned to the right */
    margin-top: 20px;
  }
{% endstyle %}

<div class="dual-cards-section">
  {% for block in section.blocks %}
    <div
      class="highlight-card"
      style="background-color: {{ block.settings.card_bg_color }}; color: {{ block.settings.card_text_color }}"
    >
      <h3>{{ block.settings.title }}</h3>
      <p>{{ block.settings.description }}</p>
      {% if block.settings.link_url != blank %}
        <a href="{{ block.settings.link_url }}" style="color: {{ block.settings.button_color }}">
          {{- block.settings.link_text -}}
        </a>
      {% endif %}
      {% if block.settings.image != blank %}
        <div class="image-wrapper">
          <img src="{{ block.settings.image | image_url: width: 200 }}" alt="">
        </div>
      {% endif %}
    </div>
  {% endfor %}
</div>
