{% schema %}
{
  "name": "Transform Health Section",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRANSFORM YOUR HEALTH : INSIDE AND OUT"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A Boost You Can Feel - Packed with Powerhouse Ingredients"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Experience It Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Transform Health Section"
    }
  ]
}
{% endschema %}

<section class="transform-health-section">
  <div class="container">
    <div class="content-left">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
      <a href="{{ section.settings.button_link }}" class="cta-button">{{ section.settings.button_text }}</a>
    </div>
    <div class="content-right">
      {% if section.settings.hero_image %}
        <img src="{{ section.settings.hero_image | image_url: width: 500 }}" alt="Healthy Woman" class="hero-image">
      {% endif %}
    </div>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <strong>90%</strong>
      <p>Success Rate</p>
    </div>
    <div class="stat">
      <strong>Only 15</strong>
      <p>Students Per Session</p>
    </div>
    <div class="stat">
      <strong>Hands-On</strong>
      <p>Surgical Training</p>
    </div>
    <div class="stat">
      <strong>Taught</strong>
      <p>By Doctors</p>
    </div>
  </div>
</section>

<style>
  .transform-health-section {
    background: linear-gradient(to bottom, #1a1a1a 50%, #ffffff 50%);
    color: #fff;
    font-family: sans-serif;
    padding: 60px 20px 0;
    position: relative;
    overflow: hidden;
  }
  .container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    max-width: 1200px;
    margin: auto;
  }
  .content-left {
    flex: 1 1 45%;
  }
  .content-left h2 {
    font-size: 2rem;
    color: #f5c356;
    margin-bottom: 10px;
  }
  .content-left p {
    color: #ccc;
    margin-bottom: 20px;
  }
  .cta-button {
    background-color: #f5c356;
    color: #2A2A2A;
    padding: 12px 24px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: bold;
  }
  .content-right {
    flex: 1 1 45%;
    position: relative;
  }
  .hero-image {
    width: 100%;
    max-width: 350px;
    border-radius: 50%;
    margin-top: -60px;
  }
  .stats-bar {
    display: flex;
    justify-content: space-around;
    text-align: center;
    padding: 40px 20px;
    background: #fff;
    color: #2A2A2A;
    flex-wrap: wrap;
  }
  .stat {
    flex: 1 1 25%;
    margin-bottom: 20px;
  }
  .stat strong {
    font-size: 1.5rem;
    color: #1a1a1a;
  }
  .stat p {
    font-size: 0.9rem;
    color: #777;
  }
</style>
