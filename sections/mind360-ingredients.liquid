{% schema %}
{
  "name": "Mind360 Ingredients",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Ingredients That Work for You"
    }, 
    {
  "type": "color",
  "id": "section_bg_color",
  "label": "Section Background Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "heading_color",
  "label": "Heading Text Color",
  "default": "#2A2A2A"
},
{
  "type": "range",
  "id": "padding_top",
  "label": "Top Padding (px)",
  "min": 0,
  "max": 100,
  "step": 4,
  "default": 40
},
{
  "type": "range",
  "id": "padding_bottom",
  "label": "Bottom Padding (px)",
  "min": 0,
  "max": 100,
  "step": 4,
  "default": 40
}

  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Ingredient Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Ingredient Title",
          "default": "Ingredient Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Ingredient Description",
          "default": "Short description of the ingredient and its benefits."
        },
    {
  "type": "color_background",
  "id": "pagination_dot_color",
  "label": "Pagination Dot Color",
  "default": "#cccccc"
},
{
  "type": "color_background",
  "id": "pagination_dot_active_color",
  "label": "Active Pagination Dot Color",
  "default": "#54BFBF"
}

      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Mind360 Ingredients Section",
      "category": "Custom"
    }
  ]
}
{% endschema %}
<div style="width:100%; background: {{ section.settings.section_bg_color }};">
<div class="mind360-section" style=" padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="mind360-container">
    {% if section.settings.heading != blank %}
      <h2 class="mind360-title" style="color: {{ section.settings.heading_color }}">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="mind360-carousel swiper swiper-container">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide mind360-slide" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                class="mind360-image"
                alt="{{ block.settings.title }}"
              >
            {% endif %}
            <h3 class="mind360-slide-title">{{ block.settings.title }}</h3>
            <p class="mind360-slide-desc" style="   line-height: 1.7 !important;">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
      <!-- Dots pagination -->
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>
</div>
<style>
  .mind360-section {
    padding: 40px 20px;
  }

  .mind360-title {
font-size: clamp(28px, 5vw, 50px) !important;
    font-weight: 700;
    color: #b4975a !important;
    margin-bottom: 10px !important;
    text-transform: uppercase;
        text-align: center;
  }

  .mind360-carousel {
    overflow: hidden;
  }

  .mind360-slide {
    text-align: left;
    border-radius: 12px;
    padding: 20px;
  }

.mind360-image {
  width: 100%;               /* Makes image stretch to full width of container */
  height: 200px;             /* Fixed height for uniform look */
  object-fit: cover;         /* Ensures image fills box while maintaining aspect ratio */
  border-radius: 6px;
  margin-bottom: 15px;
}

  .mind360-slide-title {
    font-weight: 500 !important;
    font-size: 21px;
    margin-bottom: 5px;
  }

  .mind360-slide-desc {
        line-height: 1.7 !important;
    font-size: 18px !important;
  }

  .swiper-pagination {
    text-align: center;
    margin-top: 20px;
  }

  .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
   background-color: {{ section.settings.pagination_dot_color }};
    opacity: 0.5;
    border-radius: 50%;
    margin: 0 4px;
    display: inline-block;
  }

  .swiper-pagination-bullet-active {
    background-color: #54BFBF;
    opacity: 1;
  }

  @media (min-width: 1024px) {
    .mind360-section {

      max-width: 1400px;
        margin: 0 auto;
    }
    .mind360-title {

    }

    .mind360-slide {
      padding: 30px;
    }

    .mind360-image {
      margin-bottom: 20px;
    }

    .mind360-slide-title {
      font-size: 22px;
    }

    .mind360-slide-desc {
      font-size: 16px;
    }

    .swiper-pagination-bullet {
      width: 14px;
      height: 14px;
    }
  }
  @media (max-width: 767px) {

  .mind360-slide-title {
    font-weight: 500 !important;
    font-size: 21px;
    margin-bottom: 5px;
  }

}
</style>

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.swiper-container', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
      breakpoints: {
        768: {
          slidesPerView: 3,
          spaceBetween: 30,
        }
      }
    });
  });
{% endjavascript %}
