{% comment %}
  Quality Certificates Section (Unique classes with section.id)
  — Fixed mobile marquee (CSS‑only, no JS toggle)
{% endcomment %}

<style>
  .essentials-section-{{ section.id }} {
    text-align: center;
    padding: 40px 20px;
  }

  .essentials-section-{{ section.id }} h2 {
    font-weight: bold;
    font-size: clamp(28px, 5vw, 50px) !important;
    color: #b4975a; /* gold-like color */
    margin-bottom: 45px;
    text-transform: uppercase;
  }

  /* ---------------- Desktop / Tablet (grid) ---------------- */
  .essentials-desktop-{{ section.id }} {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--icon-gap, 30px);
  }

  .essentials-icon-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .essentials-icon-{{ section.id }} img {
    max-width: 100%;
    width: var(--icon-width, 80px);
    height: auto;
    display: block;
  }

  .essentials-icon-{{ section.id }} span {
    margin-top: 10px;
    font-size: 16px;
    color: #2a2a2a;
    word-wrap: break-word;
  }

  /* Optional: special sizing for first icon (controlled via setting) */
   .essentials-icon-{{ section.id }}:first-child img {
    width: 265px !important;
    height: 75px !important;
    object-fit: contain;
  }
  
  /* ---------------- Mobile marquee ---------------- */
  .essentials-mobile-{{ section.id }} { display: none; }

  @media (max-width: 768px) {
    .essentials-desktop-{{ section.id }} { display: none; }
    .essentials-mobile-{{ section.id }} { display: block; }

    /* marquee viewport */
    .essentials-marquee-{{ section.id }} {
      overflow: hidden;
      width: 100%;
      position: relative;
    }

    /* scrolling track */
    .essentials-track-{{ section.id }} {
      display: flex;
      gap: var(--icon-gap, 30px);
      width: max-content;               /* expand to fit children */
      will-change: transform;           /* smoother animation */
      animation: essentials-scroll-{{ section.id }} var(--marquee-speed, 25s) linear infinite;
    }

    /* prevent items from shrinking */
    .essentials-icon-{{ section.id }} { flex: 0 0 auto; }
  }

  /* Keep keyframes outside media query to avoid browser quirks */
  @keyframes essentials-scroll-{{ section.id }} {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); } /* move exactly one copy width */
  }

  /* Accessibility: respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .essentials-track-{{ section.id }} { animation: none !important; }
  }

  /* First icon in EVERY loop is bigger */
.essentials-icon-{{ section.id }}.first-special img {
  width: 265px !important;
  height: 75px !important;
  object-fit: contain;
}

</style>

<section class="essentials-section-{{ section.id }}" style="--icon-width:{{ section.settings.icon_width }}px; --icon-gap:{{ section.settings.icon_gap }}px;">
  <h2>{{ section.settings.heading }}</h2>

  <!-- Desktop / Tablet Grid -->
  <div class="essentials-desktop-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="essentials-icon-{{ section.id }}">
        {% if block.settings.icon_image != blank %}
          <img src="{{ block.settings.icon_image | img_url: '200x' }}" alt="{{ block.settings.icon_text }}">
        {% endif %}
        <span>{{ block.settings.icon_text }}</span>
      </div>
    {% endfor %}
  </div>

  <!-- Mobile Marquee (duplicated content exactly twice for seamless loop) -->
  <!-- Mobile Marquee -->
<div class="essentials-mobile-{{ section.id }}">
  <div class="essentials-marquee-{{ section.id }}">
    <div class="essentials-track-{{ section.id }}">
      {% for i in (1..5) %}
        {% for block in section.blocks %}
          <div class="essentials-icon-{{ section.id }} {% if forloop.first %}first-special{% endif %}">
            {% if block.settings.icon_image != blank %}
              <img src="{{ block.settings.icon_image | img_url: '200x' }}" alt="{{ block.settings.icon_text }}">
            {% endif %}
            <span>{{ block.settings.icon_text }}</span>
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

</section>

{% schema %}
{
  "name": "Quality Certificates",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "PREMIUM QUALITY, TRUSTED BY THOUSANDS."
    },
    {
      "type": "range",
      "id": "icon_gap",
      "label": "Gap Between Icons (px)",
      "min": 5,
      "max": 100,
      "default": 30
    },
    {
      "type": "range",
      "id": "icon_width",
      "label": "Icon Width (px)",
      "min": 90,
      "max": 190,
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "first_item_custom_size",
      "label": "Custom size for first icon",
      "default": false
    },
    {
      "type": "range",
      "id": "first_item_width",
      "label": "First icon width (px)",
      "min": 260,
      "max": 360,
      "default": 265
    },
    {
      "type": "range",
      "id": "first_item_height",
      "label": "First icon height (px)",
      "min": 75,
      "max": 175,
      "default": 75
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Speed (seconds)",
      "min": 8,
      "max": 60,
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "icon_text",
          "label": "Icon Text",
          "default": "GMO-free"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Quality Badges",
      "category": "Custom"
    }
  ]
}
{% endschema %}

{% javascript %}
/* No JS needed for the marquee. If you want to control speed from settings, set it via inline style: */
(function() {
  var root = document.querySelector('.essentials-section-{{ section.id }}');
  if (root) {
    root.style.setProperty('--marquee-speed', '{{ section.settings.marquee_speed }}s');
  }
})();
{% endjavascript %}
