{% schema %}
{
  "name": "Heading with Subheading",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This is the main heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "This is the subheading text"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (px)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Heading + Subheading",
      "category": "Text"
    }
  ]
}
{% endschema %}

<section
  style="
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="custom-heading-wrapper">
    {% if section.settings.heading != blank %}
      <h2 class="custom-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="custom-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
</section>

<style>
.custom-heading {
    margin-bottom:10px;
  color: #b4975a;
  text-transform: uppercase;  
  font-size: clamp(28px, 5vw, 50px) !important;
  text-align: center;
}

.custom-subheading {
    margin: 0 auto !important;
    max-width: 700px;
    line-height: 1.4;
  font-size: 18px !important;
  color:#666 !important;
  text-align: center;
  margin: 0;
  opacity: 0.8;
}
</style>
