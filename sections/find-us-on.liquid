{% style %}
.find-us-on-section {
  text-align: center;
}

.find-us-on-section h2 {
  
   font-size: clamp(24px, 5vw, 50px) !important;
  font-weight: 700;
  color: #b4975a;
  margin-bottom: 30px;
}

.find-us-on-logos {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 80px;
  max-width: 100%;
  flex-wrap: wrap;
}

.find-us-on-logos img {
  width: {{ section.settings.logo_width }}px;
  max-width: 100%;
  height: auto;
  object-fit: contain;

  &:first-child{
    padding: 20px;
    margin-bottom: -25px
  }
}

/* Mobile Infinite Slider */
.find-us-slider {
  display: none;
  overflow: hidden;
  position: relative;
}

.find-us-slider-track {
  display: flex;
  gap: 80px;
  width: max-content;
  align-items: anchor-center;
  animation: scrollLogos 30s linear infinite;
  padding-bottom: clamp(25px, 6%, 45px);
}

.find-us-slider img {
  width: {{ section.settings.logo_width }}px;
  /* height: {{ section.settings.logo_height }}px; */
  object-fit: contain;
  
  &:nth-child(odd){
    margin-bottom: clamp(-25px, -6%, -45px);
  }
}

@keyframes scrollLogos {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* Responsive Toggle */
@media (max-width: 768px) {
  .find-us-on-logos {
    display: none;
  }

  .find-us-slider {
    display: block;
  }
}

@media (min-width: 769px) {
  .find-us-slider {
    display: none;
  }
}
{% endstyle %}
<section
  class="find-us-on-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: 0px;
  "
>
  <h2>FIND US ON</h2>

  <!-- Desktop Logos -->
  <div class="find-us-on-logos"  style="
    background: #F5F2EC;">
    {% for i in (1..8) %}
      {% assign setting_key = "logo_" | append: i %}
      {% assign logo = section.settings[setting_key] %}
      {% if logo != blank %}
       <img src="{{ logo | image_url: width: 300 }}" alt="Brand Logo {{ i }}" style="height: {{ section.settings.logo_height }}px;; width: {{ section.settings.logo_width }}px;">

      {% endif %}
    {% endfor %}
  </div>

  <!-- Mobile Infinite Slider -->
  <div class="find-us-slider">
    <div class="find-us-slider-track">
      {% for repeat in (1..3) %}
        {% for i in (1..8) %}
          {% assign setting_key = "logo_" | append: i %}
          {% assign logo = section.settings[setting_key] %}
          {% if logo != blank %}
            <img src="{{ logo | image_url }}" alt="Brand Logo {{ i }}">
          {% endif %}
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>



