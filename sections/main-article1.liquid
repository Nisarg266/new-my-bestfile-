{% comment %}
  Blog Post Template Section
{% endcomment %}

<style>
.blog-post-container {
  max-width: 100%;
  margin: 0 auto;
}
.blog-featured-image img {
  width: 100%;
  height: auto;
  margin-bottom: 30px;
}

/* Desktop and Mobile Image Switching */
.blog-featured-image .desktop-image {
  display: block;
}

.blog-featured-image .mobile-image {
  display: none;
}

@media (max-width: 768px) {
  .blog-featured-image .desktop-image {
    display: none;
  }
  
  .blog-featured-image .mobile-image {
    display: block;
  }
}
.blog-layout {
    max-width:1300px;
    margin:0 auto;
        padding: 0px 20px;
        padding-bottom:40px;
  display: grid;
  grid-template-columns: 70% 30%;
  gap: 30px;
}

@media (max-width: 768px) {
  .blog-layout {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 0px 15px;
    padding-bottom: 30px;
  }
  
  .blog-sidebar {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid #e0e0e0;
  }
  
  .leave-comment .name-row {
    flex-direction: column;
    gap: 0;
  }
  
  .leave-comment .name-row input {
    width: 100%;
  }
  
  .newsletter form {
    flex-direction: column;
  }
  
  .newsletter input {
    width: 100%;
    margin-bottom: 10px;
  }
  
  .newsletter button {
    width: 100%;
    margin: 0;
    padding: 15px 25px;
  }
  
  .share-post .icons a {
    width: 35px;
    height: 35px;
  }
  
  .writer-block {
    flex-wrap: wrap;
    text-align: center;
  }
  
  .writer-block img {
    width: 50px;
    height: 50px;
  }
  
  .related-card-content h4 {
    font-size: 16px;
  }
  
  .leave-comment input,
  .leave-comment textarea {
    padding: 15px;
    font-size: 16px;
  }
  
  .leave-comment button,
  .newsletter button {
    font-size: 18px !important;
  }
}
.writer-block {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 20px;
}
.writer-block img {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  object-fit: cover;
}
.writer-info p {
  margin: 0;
  font-size: 14px;
}
.writer-info strong {
  color: #000;
}
.share-post, .leave-comment, .newsletter {
  margin-top: 30px;
}
.leave-comment p {
    margin-top:0px;
    margin-bottom:15px;

}
.share-icons {
  display: flex;
  gap: 12px;
  margin-top: 10px;
}
.share-icons a svg {
  width: 22px;
  height: 22px;
  fill: #000;
  transition: 0.2s ease;
}
.share-icons a:hover svg {
  fill: #b68d3d;
}
.leave-comment input, 
.leave-comment textarea {
  width: 100%;
  padding: 12px;
  margin-bottom: 12px;
 border: 2px solid black;
  border-radius: 6px;
}
.leave-comment .name-row {
  display: flex;
  gap: 15px;
}
.leave-comment .name-row input {
  flex: 1;
}
.leave-comment button,
.newsletter button {
  background: #b68d3d;
  color: #fff;
  border: none;
  padding: 10px 20px;
  border-radius: 6px;
  cursor: pointer;
}
.related-articles h3 {
  margin-bottom: 15px;
}
.related-card {
  
  overflow: hidden;
  margin-bottom: 20px;
}
.related-card img {
  width: 100%;
  height: auto;
}
.related-card-content {
}
.related-card-content h4 {
  font-size: 18px;
    line-height: 1.2;
  margin: 0 0 8px;
}
.related-card-content p {
  font-size: 14px !important;
  color: #666;
  margin: 0 0 12px;
  display: -webkit-box;
  -webkit-line-clamp: 2; /* exactly 2 lines */
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.related-card-content a {
  display: inline-block;
  background: #b4975a;
  color: #2a2a2a;
  padding: 8px 20px;
  border-radius: 4px;
  font-size: 23px !important;
  font-weight: 500 !important;
  text-decoration: none;
  transition: background-color 0.3s ease;
}

.related-card-content a:hover {
  background: #2a2a2a;
  color: #b4975a;
}

.share-post {
  margin-top: 30px;
}
.share-post h3 {
  font-weight: 600;
  margin-bottom: 15px;
}
.share-post .icons {
  display: flex;
  gap: 12px;
}
.share-post .icons a {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f2f2f2;
  color: #000;
  text-decoration: none;
  transition: all 0.3s ease;
}
.share-post .icons a:hover {
  background: #000;
  color: #fff;
}
.newsletter h3{
margin-bottom:15px;
}

.leave-comment h3,
.newsletter h3 {
  font-weight: 700;
  margin-bottom: 5px;
}

.leave-comment p,
.newsletter p {
  margin-top:0px;
  font-size: 14px;
  color: #555;
  margin-bottom: 15px;
}

.leave-comment input,
.leave-comment textarea,
.newsletter input {
    width: 100%;
    padding: 20px;
    border: 2px solid #000;
    border-radius: 6px;
    font-size: 18px !important;
}

.leave-comment .name-row {
  display: flex;
  gap: 20px;
}

.leave-comment .name-row input {
  flex: 1;
}

.leave-comment button,
.newsletter button {
  font-size: 23px !important;
  background: #b4975a;
  color: #2a2a2a;
  border: none;
  padding: 8px 20px;
  border-radius: 4px;
  font-weight: 500 !important;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.leave-comment button:hover,
.newsletter button:hover {
  background: #000;
  color: #b4975a;
}

.newsletter form {
  display: flex;
  gap: 15px;
}

.newsletter input {
  flex: 1;
}
.newsletter h3 {
  font-weight: 700;
  margin-bottom: 5px;
}

.newsletter p {
  font-size: 14px;
  color: #555;
  margin-bottom: 15px;
}

.newsletter form {
  display: flex;
  border: 2px solid #000;
  border-radius: 6px;
  overflow: hidden; /* keeps button inside */
}

.newsletter input {
  flex: 1;
  padding: 17px 15px;
  border: none;
  outline: none;
  font-size: 14px;
}

.newsletter button {
  margin: 7px;
  background: #b4975a;
  color: #2a2a2a;
  font-weight: 500 !important;
  font-size: 23px !important;
  border: none;
  padding: 8px 20px;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.newsletter button:hover {
  background: #000;
  color: #fff;
}

/* Table of Contents Styles */
.article-toc {
  background: #f8f8f8;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 30px;
  position: sticky;
  top: 20px;
}

.article-toc h3 {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 15px;
  color: #000;
}

.toc-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc-list li {
  position: relative;
  padding-left: 20px;
  margin-bottom: 12px;
  font-size: 14px;
  line-height: 1.4;
}

.toc-list li:before {
  content: '';
  position: absolute;
  left: 0;
  top: 6px;
  width: 8px;
  height: 8px;
  background: #b68d3d;
  border-radius: 50%;
}

.toc-list li.active:before {
  background: #000;
  width: 10px;
  height: 10px;
  top: 5px;
}

.toc-list a {
  color: #666;
  text-decoration: none;
  transition: color 0.3s ease;
  display: block;
}

.toc-list a:hover {
  color: #b68d3d;
}

.toc-list li.active a {
  color: #000;
  font-weight: 600;
}

/* Vertical line connecting dots */
.toc-list:before {
  content: '';
  position: absolute;
  left: 4px;
  top: 0;
  bottom: 0;
  width: 1px;
  background: #ddd;
}

.toc-list {
  position: relative;
}

@media (max-width: 768px) {

  .leave-comment button, .newsletter button{
    font-size: 18px !important;
  padding: 5px 15px;
  font-weight: 500 !important;
  
  }
.newsletter button {
margin: 0px;

}
  .article-toc {
    position: static;
    margin-bottom: 20px;
  }
}
.blog-author {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-top: 20px;
}

.blog-author .author-img {
  margin-bottom:20px;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
}

.blog-author .author-details {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.blog-author .author-details p {
  margin: 0;
  font-size: 14px;
  line-height: 1.4;
}
.author-details strong{
font-weight:bold !important;
color:#2a2a2a !important;
}
.blog-content h2{
font-size:32px !important;
}
</style>

<div class="blog-post-container">

  <!-- Featured Image -->
  <div class="blog-featured-image">
    {% if article.image %}
      {% assign mobile_image = article.metafields.custom.mobile_featured_image.value %}
      {% if mobile_image %}
        <!-- Desktop Image -->
        <img class="desktop-image" src="{{ article.image | img_url: '1500x' }}" alt="{{ article.title }}">
        <!-- Mobile Image -->
        <img class="mobile-image" src="{{ mobile_image | img_url: '800x' }}" alt="{{ article.title }} - Mobile">
      {% else %}
        <!-- Default image for both desktop and mobile -->
        <img src="{{ article.image | img_url: '1500x' }}" alt="{{ article.title }}">
      {% endif %}
    {% endif %}
  </div>

  <div class="blog-layout">

    <!-- Left Column 70% -->
    <div class="blog-main">
      
    <div class="blog-author">
  {% if article.metafields.custom.author_image %}
    <img class="author-img" 
         src="{{ article.metafields.custom.author_image | image_url: width: 100, height: 100, crop: 'center' }}" 
         alt="{{ article.author }}">
  {% elsif article.user.image %}
    <img class="author-img" 
         src="{{ article.user.image | img_url: '100x100' }}" 
         alt="{{ article.author }}">
  {% endif %}

  <div class="author-details">
    <p>Writer:<strong> {{ article.metafields.custom.authorname }} </strong></p>
    <p>Updated On:<strong> {{ article.updated_at | date: "%d/%m/%Y" }}</strong></p>
  </div>
</div>
      <!-- Blog Content -->
      <div class="blog-content">
        {{ article.content }}
      </div>

