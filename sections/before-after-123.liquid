{% comment %}
  Two Column Before & After Section
{% endcomment %}

<style>
  .two-col-before-after {
    padding: 30px 20px;
  }
  .two-col-before-after__container {
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    align-items: center;
  }

  /* Left Content */
  .two-col-before-after__content {
        padding: 80px;
    text-align: left;
  }
  .two-col-before-after__heading {
    font-size: clamp(26px, 5vw, 50px);
    color: #b4975a;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .two-col-before-after__icon-text {
    display: flex;
    align-items: center;
    margin-bottom: 1rem;
    gap: 0.6rem;
  }
{% comment %} .two-col-before-after__icon-text img {
  width: 80px;              /* circle size */
  height: 80px;
  border-radius: 50%;       /* circular */
  background: black;        /* circle background */
  object-fit: contain;      /* keeps full icon visible */
  padding: 6px;             /* less padding so icon looks bigger */
  box-sizing: border-box;
} {% endcomment %}

.icon-circle12 {
  width: 85px;
  height: 85px;
  border-radius: 50%;
  background: #b4975a;
  display: flex;
  align-items: center;
  justify-content: center; /* centers the icon */
  flex-shrink: 0; /* keeps size consistent */
}

.icon-circle12 img {
  max-width: 65%;   /* adjust until your icons look balanced */
  max-height: 65%;
  object-fit: contain;
}


  .two-col-before-after__subheading {
    font-size: clamp(16px, 2vw, 20px);
    margin-bottom: 1.5rem;
    color: #2a2a2a;
  }
  .two-col-before-after__btn {
    padding: 12px 28px;
    font-size: 30px !important;
    font-weight: 600 !important;
    display: inline-block;
    background-color: #1e1e1e;
    color: #b4975a;
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.3s ease;
    max-width: max-content;
    text-align: center;
  }
  .two-col-before-after__btn:hover {
    background: #b4975a;
    color: #2a2a2a;
    border: 1px solid black;
  }


  /* Right Slider (Your Previous Code Adjusted) */
.before-after-slider {
  margin-left:65px;
  position: relative;
  overflow: hidden;
  width: 460px;
    height: 650px;/* NEW */
  border-radius: 0.8rem;
  --pos: 50%;
  --transition-speed: 0.25s;
}
  .before-after-slider img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
    user-select: none;
    transition: clip-path var(--transition-speed) ease-out;
  }
  .before-image { z-index: 1; }
  .after-image {
    z-index: 2;
    clip-path: polygon(0 0, var(--pos) 0, var(--pos) 100%, 0 100%);
  }
  .slider-handle {
    position: absolute;
    top: 0;
    left: var(--pos);
    transform: translateX(-50%);
    width: 4px;
    height: 100%;
    background: white;
    z-index: 3;
    /* Removed transition for instant response */
  }
  .slider-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: white;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: grab;
    transition: transform 0.2s ease;
  }
  .slider-circle:active {
    cursor: grabbing;
    transform: translate(-50%, -50%) scale(1.05);
  }
  .slider-circle svg {
    width: 18px;
    height: 18px;
    fill: black;
  }
input[type="range"].before-after-range {
  position: absolute;
  inset: 0;
  appearance: none;
  -webkit-appearance: none;
  -moz-appearance: none;
  background: transparent;
  cursor: pointer;
  z-index: 4;
  outline: none;
}

/* Remove the blue dot on Chrome/Safari/Edge */
input[type="range"].before-after-range::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  background: transparent;
  border: none;
  width: 0;
  height: 0;
}

/* Remove the blue dot on Firefox */
input[type="range"].before-after-range::-moz-range-thumb {
  appearance: none;
  background: transparent;
  border: none;
  width: 0;
  height: 0;
}

  input[type="range"]::-webkit-slider-thumb,
  input[type="range"]::-moz-range-thumb {
    appearance: none;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
  }

  /* Left Content */
.two-col-before-after__content {
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.two-col-before-after__heading {
  font-size: clamp(28px, 4vw, 50px);
  color: #b4975a;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}

.two-col-before-after__icon-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.two-col-before-after__icon-text {
  display: flex;
  align-items: center;
  gap: 2.8rem;
  padding-bottom: 1.8rem;
  border-bottom: 2px solid #b4975a; /* gold border */
}

.two-col-before-after__icon-text img {

  object-fit: contain;
}

.two-col-before-after__icon-text span {
  color:#2a2a2a;
  font-weight: 400;
  font-size: clamp(16px, 1.8vw, 22px);
}

.two-col-before-after__subheading {
    color:#2a2a2a !important;

  font-weight: bold !important;
  font-size: clamp(16px, 2vw, 22px)!important;
  margin-top: 0.5rem;
}

.two-col-before-after__btn {
  display: inline-block;
  background: black;
  color: #b4975a;
  padding: 8px 20px;
  border-radius: 4px;
  text-decoration: none;
  font-weight: 500 !important;
  font-size: 23px !important;
  transition: background 0.3s ease;
}

.two-col-before-after__btn:hover {
  background: #a27d2b;
}
@media (max-width: 768px) {
  .two-col-before-after__btn {
     margin: 0 auto; /* Ensure button itself centers */
  display: inline-block;
  background: black;
  color: #b4975a;
  padding: 5px 15px;
  border-radius: 4px;
  text-decoration: none;
  font-weight: 500 !important;
  font-size: 18px !important;
  transition: background 0.3s ease;
}

  .two-col-before-after__container{
  display: flex;
    flex-direction: column-reverse;
    gap: 30px;
    align-items: normal;
  
  }
  .two-col-before-after__heading {
  
    text-align:center;
  }
  .two-col-before-after__content {
    padding: 0; /* remove padding on mobile */
    padding-left:20px;
    padding-right:20px;
  }
  .before-after-slider
  {
        width: auto;
        height: 135vw;
  margin-left: 0px;
  }
}

</style>

<div class="two-col-before-after">
  <div class="two-col-before-after__container">

    <!-- Left Content -->
 <!-- Left Content -->
<div class="two-col-before-after__content">
  {% if section.settings.heading != blank %}
    <h2 class="two-col-before-after__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="two-col-before-after__icon-list">
    {% if section.settings.icon1 != blank and section.settings.icon1_text != blank %}
      <div class="two-col-before-after__icon-text">
        <div class="icon-circle12">
        <img src="{{ section.settings.icon1 | image_url }}" alt="Icon 1">
        </div>
        <span>{{ section.settings.icon1_text }}</span>
      </div>
    {% endif %}
    {% if section.settings.icon2 != blank and section.settings.icon2_text != blank %}
      <div class="two-col-before-after__icon-text">
        <div class="icon-circle12">
        <img src="{{ section.settings.icon2 | image_url }}" alt="Icon 2">
        </div>
        <span>{{ section.settings.icon2_text }}</span>
    
      </div>
    {% endif %}
    {% if section.settings.icon3 != blank and section.settings.icon3_text != blank %}
      <div class="two-col-before-after__icon-text">
        <div class="icon-circle12">
        <img src="{{ section.settings.icon3 | image_url }}" alt="Icon 3">
        </div>
        <span>{{ section.settings.icon3_text }}</span>

      </div>
    {% endif %}
  </div>

  {% if section.settings.subheading != blank %}
    <p class="two-col-before-after__subheading">{{ section.settings.subheading }}</p>
  {% endif %}

  {% if section.settings.button_label != blank and section.settings.button_link != blank %}
    <a href="{{ section.settings.button_link }}" class="two-col-before-after__btn">
      {{ section.settings.button_label }}
    </a>
  {% endif %}
</div>


    <!-- Right Before & After Slider -->
    <div>
      <div class="before-after-slider">
        {% if section.settings.before_image != blank %}
          <img src="{{ section.settings.before_image | image_url }}" alt="Before Image" class="before-image">
        {% endif %}
        {% if section.settings.after_image != blank %}
          <img src="{{ section.settings.after_image | image_url }}" alt="After Image" class="after-image">
        {% endif %}

        <div class="slider-handle">
          <div class="slider-circle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M10 6l-6 6 6 6V6zm4 12l6-6-6-6v12z"/>
            </svg>
          </div>
        </div>

        <input type="range" class="before-after-range" min="0" max="100" value="50" aria-label="Comparison Slider">
      </div>
    </div>

  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  document.querySelectorAll('.before-after-slider').forEach(function(slider) {
    const afterImg = slider.querySelector('.after-image');
    const handle = slider.querySelector('.slider-handle');

    let isDragging = false;

    function updateSlider(x) {
      let rect = slider.getBoundingClientRect();
      let offsetX = x - rect.left;
      let percentage = Math.max(0, Math.min(100, (offsetX / rect.width) * 100));
      slider.style.setProperty('--pos', percentage + '%');
      afterImg.style.clipPath = `polygon(0 0, ${percentage}% 0, ${percentage}% 100%, 0 100%)`;
      handle.style.left = percentage + '%';
    }

    slider.addEventListener('mousedown', e => {
      isDragging = true;
      updateSlider(e.clientX);
    });
    slider.addEventListener('touchstart', e => {
      isDragging = true;
      updateSlider(e.touches[0].clientX);
    });

    window.addEventListener('mousemove', e => {
      if (isDragging) updateSlider(e.clientX);
    });
    window.addEventListener('touchmove', e => {
      if (isDragging) updateSlider(e.touches[0].clientX);
    });

    window.addEventListener('mouseup', () => isDragging = false);
    window.addEventListener('touchend', () => isDragging = false);
  });
});
</script>

{% schema %}
{
  "name": "Two Column Before & After",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "See The Transformation" },
    { "type": "image_picker", "id": "icon1", "label": "Icon 1" },
{ "type": "text", "id": "icon1_text", "label": "Icon 1 Text" },
{ "type": "image_picker", "id": "icon2", "label": "Icon 2" },
{ "type": "text", "id": "icon2_text", "label": "Icon 2 Text" },
{ "type": "image_picker", "id": "icon3", "label": "Icon 3" },
{ "type": "text", "id": "icon3_text", "label": "Icon 3 Text" },

    { "type": "text", "id": "icon_text", "label": "Icon Text", "default": "Premium Quality" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Before and after using our product." },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "image_picker", "id": "before_image", "label": "Before Image" },
    { "type": "image_picker", "id": "after_image", "label": "After Image" },
    { "type": "text", "id": "aspect_ratio", "label": "Aspect Ratio", "default": "16/9" }
  ],
  "presets": [
    { "name": "Two Column Before & After", "category": "Image" }
  ]
}
{% endschema %}
