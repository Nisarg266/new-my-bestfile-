{% schema %}
{
  "name": "Made for Modern Lifestyle",
  "tag": "section",
  "class": "section-modern-lifestyle",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Main Title",
      "default": "Real Benefits. Real Results."
    },
    {
  "type": "color",
  "id": "background_color",
  "label": "Section Background Color",
  "default": "#ffffff"
},
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Top Spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Bottom Spacing",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "1", "label": "Small" },
        { "value": "2", "label": "Medium" },
        { "value": "4", "label": "Large" },
        { "value": "6", "label": "XL" }
      ],
      "default": "0"
    },
             {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
  "type": "range",
  "id": "left_padding",
  "label": "Left padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
{
  "type": "range",
  "id": "right_padding",
  "label": "Right padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
        {
      "type": "checkbox",
      "id": "pagination",
      "label": "Pagination",
      "default": true
    },
    {
  "type": "checkbox",
  "id": "showslider_mobile",
  "label": "Enable Slider on Mobile",
  "default": true
},
     {
      "type": "range",
      "id": "slides_per_view_mobile",
      "label": "Slides Per View (Mobile)",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 2.2
    },
  ],
  "blocks": [
    {
      "type": "lifestyle_card",
      "name": "Lifestyle Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card Title",
          "default": "Card Title"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Made for Modern Lifestyle"
    }
  ]
}
{% endschema %}
{%- style -%}
  .section-{{ section.id }}-padding {
     background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.top_padding | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.bottom_padding | times: 0.75 | round: 0 }}px;
    padding-left: {{ section.settings.left_padding | times: 0.75 | round: 0 }}px;
    padding-right: {{ section.settings.right_padding | times: 0.75 | round: 0 }}px;
       

  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.top_padding }}px;
      padding-bottom: {{ section.settings.bottom_padding }}px;
      padding-left: {{ section.settings.left_padding }}px;
      padding-right: {{ section.settings.right_padding }}px;
    }
  }
{%- endstyle -%}
<div class="section-modern-lifestyle {{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="section-container container">
    <h2 class="section__heading">
      {{ section.settings.heading }}
    </h2>

    <div class="cards-wrapper ma-modern-slider-{{ section.id }}">
      <div class="moderncards">
        {% for block in section.blocks %}
          <div class="lifestyle-card">
            <div class="modernimagecontainer">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | img_url: '280x280' }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <h3>{{ block.settings.title }}</h3>
          </div>
        {% endfor %}
      </div>
      <div class="modernscrolldots">
        {% for block in section.blocks %}
          <span {% if forloop.first %}class="active"{% endif %}></span>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% if section.settings.showslider_mobile %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const container = document.querySelector('.ma-modern-slider-{{ section.id }}');
      const cardsContainer = container.querySelector('.moderncards');
      const dots = container.querySelectorAll('.modernscrolldots span');
      const cards = container.querySelectorAll('.lifestyle-card');

      // Only run on mobile (width <= 768px)
      if (container && window.innerWidth <= 768) {
        let currentIndex = 0;
        const totalCards = cards.length;

        // Function to update active card and dot
        function updateActiveCard(index) {
          // Update cards visibility
          cards.forEach((card, i) => {
            if (i === index) {
              card.style.display = 'block';
            } else {
              card.style.display = 'none';
            }
          });

          // Update dots
          dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });

          currentIndex = index;
        }

        // Initialize - show first card
        updateActiveCard(0);

        // Add touch/swipe functionality
        let startX = 0;
        let endX = 0;

        cardsContainer.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
        });

        cardsContainer.addEventListener('touchend', (e) => {
          endX = e.changedTouches[0].clientX;
          handleSwipe();
        });

        function handleSwipe() {
          const swipeThreshold = 50;
          const diff = startX - endX;

          if (Math.abs(diff) > swipeThreshold) {
            if (diff > 0 && currentIndex < totalCards - 1) {
              // Swipe left - next card
              updateActiveCard(currentIndex + 1);
            } else if (diff < 0 && currentIndex > 0) {
              // Swipe right - previous card
              updateActiveCard(currentIndex - 1);
            }
          }
        }

        // Add click functionality to dots
        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            updateActiveCard(index);
          });
        });
      }
    });
  </script>
{% endif %}

<style>
/* Base styles */
.section-modern-lifestyle {
  text-align: center;

}

.section-container {
     
  max-width: 1600px;
  margin: 0 auto;
  width: 100%;
}

.section__heading {
    font-size: clamp(28px, 5vw, 50px) !important;
  font-weight: bold;
  margin-bottom: 20px;
  color: #b4975a;
  text-transform:uppercase;}

.cards-wrapper {
  position: relative;
}

/* Mobile: scrollable cards */
.moderncards {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 1rem;
}

.moderncards::-webkit-scrollbar {
  display: none;
}

.lifestyle-card {
        max-width: 30.33%;
  flex: 0 0 100%;
  scroll-snap-align: start;
  border-radius: 8px;
  text-align: center;
  transition: transform 0.3s ease;
}

.lifestyle-card h3 {
  line-height: 1.4;
}

.lifestyle-card:hover {
  transform: translateY(-5px);
}

/* Image styling */
.modernimagecontainer img {
  width: 100%;
  height: 100%;
max-height: 100%;
  max-width: 100%;
  object-fit: cover;
border-radius: 13px;
}

/* Scroll dots for mobile */
.modernscrolldots {
  display: flex;
  justify-content: center;
  margin-top: 12px;
  gap: 6px;
}

.modernscrolldots span {
  width: 8px;
  height: 8px;
  background-color: #ccc;
  border-radius: 50%;
  display: inline-block;
}

.modernscrolldots span.active {
  background-color: #333;
}


/* Desktop: show 3 cards in a row */
@media (min-width: 1024px) {
  .moderncards {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 2rem;
    overflow: unset;
  }

  .lifestyle-card {
    flex: 0 0 calc((100% - 4rem) / 3); /* 3 cards with 2rem gap between */
    scroll-snap-align: unset;
  }

  .modernscrolldots {
    display: none;
  }
}

@media (max-width: 768px) {
   .lifestyle-card {
    max-width: 100%;
  }
.section-modern-lifestyle {
  text-align: center;
  padding: 10px;
}
}
</style>
