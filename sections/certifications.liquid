                        }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const swiper = new Swiper('.cert-swiper', {
      navigation: {
        nextEl: '.ma-next',
        prevEl: '.ma-prev'
      },
      on: {
        init: updateCertIcons,
        slideChange: updateCertIcons
      }
    });

function updateCertIcons() {
  const icons = document.querySelectorAll('.cert-icon');
  icons.forEach(icon => icon.classList.remove('active'));

  const swiperInstance = document.querySelector('.cert-swiper')?.swiper;
  if (!swiperInstance) return;

  const activeSlide = swiperInstance.slides[swiperInstance.activeIndex];
  if (!activeSlide) return;

  let cert = activeSlide.dataset.cert || '';
  cert = cert.trim().toLowerCase().replace(/\s+/g, '-'); 

  const activeIcon = document.querySelector(`.cert-icon-${cert}`);
  if (activeIcon) {
    activeIcon.classList.add('active');
  } else {
    console.warn(`No icon found for .cert-icon-${cert}`);
  }
}


  });
</script>

