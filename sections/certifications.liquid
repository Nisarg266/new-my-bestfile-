<div class="ingredient-certification-section container">
  <div class="ingredient-certification-section-inner">
    <div class="cert-heading">
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

    <div class="swiper cert-swiper">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" data-index="{{ forloop.index0 }}" data-cert="{{ block.settings.cert_id }}">
            <div class="cert-slide-content">
              <div class="cert-meta">
                <div class="cert-meta-headings">
                  <h4>{{ block.settings.name }}</h4>
                  <p>{{ block.settings.details }}</p>
                </div>
                              <div class="cert-nav">
                  <button class="ma-prev">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="17" viewBox="0 0 20 17" fill="none">
                      <path d="M19 8.5L0.999999 8.5M0.999999 8.5L8.5 16M0.999999 8.5L8.5 1" stroke="#2F2F2F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <button class="ma-next">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="17" viewBox="0 0 20 17" fill="none">
                      <path d="M19 8.5L0.999999 8.5M0.999999 8.5L8.5 16M0.999999 8.5L8.5 1" stroke="#2F2F2F" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}

      </div>

    </div>
  </div>

  <div class="cert-icons">
    {% for block in section.blocks %}
      <div
        class="cert-icon  cert-icon-{{ block.settings.cert_id | downcase | replace: ' ', '-' }}"
        data-index="{{ forloop.index0 }}"
        data-cert="{{ block.settings.cert_id | downcase | replace: ' ', '-' }}"
      >
        {% if block.settings.icon1 != blank %}
          <div class="cert-award">
            <img src="{{ block.settings.icon1 | img_url: 'master' }}" alt="{{ block.settings.label1 }}">
            <span>{{ block.settings.label1 }}</span>
          </div>
        {% endif %}

        {% if block.settings.icon2 != blank %}
          <div class="cert-award">
            <img src="{{ block.settings.icon2 | img_url: 'master' }}" alt="{{ block.settings.label2 }}">
            <span>{{ block.settings.label2 }}</span>
          </div>
        {% endif %}

        {% if block.settings.icon3 != blank %}
          <div class="cert-award">
            <img src="{{ block.settings.icon3 | img_url: 'master' }}" alt="{{ block.settings.label3 }}">
            <span>{{ block.settings.label3 }}</span>
          </div>
        {% endif %}

        {% if block.settings.icon4 != blank %}
          <div class="cert-award">
            <img src="{{ block.settings.icon4 | img_url: 'master' }}" alt="{{ block.settings.label4 }}">
            <span>{{ block.settings.label4 }}</span>
          </div>
        {% endif %}

        {% if block.settings.icon5 != blank %}
          <div class="cert-award">
            <img src="{{ block.settings.icon5 | img_url: 'master' }}" alt="{{ block.settings.label5 }}">
            <span>{{ block.settings.label5 }}</span>
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<style>

