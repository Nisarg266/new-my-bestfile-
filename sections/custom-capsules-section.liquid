{% schema %}
{
  "name": "Core Benefits",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section Heading",
      "default": "CORE BENEFITS"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Benefit Icon"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Benefit Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Benefit subheading goes here."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Core Benefits"
    }
  ]
}
{% endschema %}

<div class="core-benefits-wrapper">
        <h2 class="core-benefits-heading">{{ section.settings.section_heading }}</h2>

  <div class="core-benefits-content">

    <div class="core-benefits-image">
      {% if section.settings.main_image != blank %}
        <img src="{{ section.settings.main_image | img_url: 'master' }}" alt="Core Benefits Image">
      {% endif %}
    </div>
    <div class="core-benefits-benefits">
      {% for block in section.blocks %}
        <div class="benefit-item">
          {% if block.settings.icon != blank %}
            <div class="benefit-icon">
              <img src="{{ block.settings.icon | img_url: 'master' }}" alt="Benefit Icon">
            </div>
          {% endif %}
          <div class="benefit-texts">
            <h3 class="benefit-heading">{{ block.settings.heading }}</h3>
            <p class="benefit-subheading">{{ block.settings.subheading }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.core-benefits-wrapper {
  max-width: 1200px;
  margin: 0 auto;
  padding: 60px 20px;
  text-align: center;
}
.core-benefits-heading {
     font-size: clamp(28px, 5vw, 50px) !important;
    font-weight: 700 !important;
  color: #b4975a;
  padding-bottom:30px;
  text-transform: uppercase;
}
.core-benefits-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}
.core-benefits-image {
  flex: 1 1 300px;
  max-width: 500px;
    display: flex;
    justify-content: end;
    align-items: center;
}
.core-benefits-image img {
  width: 100%;
  border-radius: 100%;
}
.core-benefits-benefits {
    flex: 1 1 500px;

    margin-left: 30px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  justify-content: center;
}
.benefit-item {
  background: #eeebe3;
    border-radius: 100px;
  padding: 30px 30px;
  display: flex;
  align-items: center;
  text-align: left;
}
.benefit-icon {
  flex-shrink: 0;
  width: 60px;
  height: 60px;
  margin-right: 20px;
   margin-left: 20px;
}
.benefit-icon img {
  width: 100%;
  height: auto;
}
.benefit-heading {
  font-size: 20px !important;
  font-weight: 700;
  margin: 0 0 5px;
}
.benefit-subheading {
  font-size: 18px !important;
  margin: 0;
  color: #555;
}
@media (max-width: 768px) {
  .core-benefits-wrapper {
  padding: 30px 20px;
 }
  .core-benefits-image {
    padding-bottom:20px;
  }
  .core-benefits-content {
    flex-direction: column;
  }
  .core-benefits-benefits {
            flex: 1 1 340px;
    width: 100%;
    margin-left:0px;
justify-content: normal;
  }
.core-benefits-heading {
padding-top:0px;
}
.benefit-icon {
  flex-shrink: 0;
  width: 40px;
  height: 40px;
  margin-right: 10px;
   margin-left: 10px;
}

.benefit-heading {
  font-size: 14px !important;
  font-weight: 700 !important;
  margin: 0 0 5px;
}
.benefit-subheading {
  font-size: 14px !important;
  margin: 0;
  color: #555;
}
}
</style>
