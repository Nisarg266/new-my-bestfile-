<section
  class="custom-hero-image-container clickable-block"
  style="
    background-color: {{ section.settings.background_color }};
    {% comment %} height: {{ section.settings.section_height }}; {% endcomment %}
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    width: 100%;
    position: relative;
    overflow: hidden;
  "
    {% if section.settings.button_link != blank %}
    onclick="window.location.href='{{ section.settings.button_link }}'"
  {% endif %}
>
  <style>
       .clickable-block[onclick] {
    cursor: pointer;
  }
    .custom-hero-bg-img {
      object-position: center;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      {% comment %} height: 100%; {% endcomment %}
             aspect-ratio: {{ section.settings.background_image.width }}/{{ section.settings.background_image.height }};

             object-fit: fill;
             z-index: 0;
            }
            .custom-hero-image-container{
              aspect-ratio: {{ section.settings.background_image.width }}/{{ section.settings.background_image.height }};
            }
    .custom-bg-desktop {
      display: block;
    }

    .custom-bg-mobile {
      display: none;
    }

    .custom-hero-inner {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: flex-start;
      align-items: center;
      max-width: 1300px;
      margin: 0 auto;
      height: 100%;
    }

    .custom-hero-left {
      flex: 0 0 60%;
      text-align: left;
      padding: 20px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
    }

    .custom-hero-small-heading {
      font-size: 22px;
      font-weight: 600;
      margin-bottom: 10px;
      color: {{ section.settings.heading_color }};
    }

    .custom-hero-heading {
      font-size: {{ section.settings.heading_size }}px;
      font-weight: bold;
      color: {{ section.settings.heading_color }};
      text-transform: uppercase;
      line-height: initial;
    }

    .custom-hero-subheading {
    letter-spacing: -1.5px;
          font-size: clamp(18px, 5vw, 30px) !important;

      margin-bottom: 40px;
      color: {{ section.settings.subheading_color }};
    }

    .custom-hero-button {
      background-color: {{ section.settings.button_bg_color }};
      color: {{ section.settings.button_text_color }};
      padding: 12px 24px;
      border: none;

      cursor: pointer;
      text-decoration: none;
      font-size: 23px !important;
      font-weight: 600 !important;
      border-radius: 4px;
      margin-right: 12px;
    }

    .custom-hero-button:hover {
      background-color: {{ section.settings.button_hover_bg_color }};
      color: {{ section.settings.button_hover_text_color }};
    }

    @media screen and (max-width: 749px) {
      .custom-hero-image-container {
        {% comment %} height: 80vh !important; {% endcomment %}
      }

      .custom-hero-bg-img, .custom-hero-image-container {
        aspect-ratio: {{ section.settings.mobile_background_image.width }}/{{ section.settings.mobile_background_image.height }}
      }
      .custom-bg-desktop {
        display: none;
      }

      .custom-bg-mobile {
        display: block;
      }

      .custom-hero-inner {
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 0 10px;
      }

      .custom-hero-left {
        align-items: center;
        text-align: center;
      }

      .custom-hero-heading {
        font-size: 32px;
      }

      .custom-hero-subheading {
        letter-spacing: 0.5px;
      }
    }
  </style>

  {% if section.settings.background_image != blank %}
    <img
      src="{{ section.settings.background_image | image_url: width: 1800 }}"
      alt="Desktop Background"
      class="custom-hero-bg-img custom-bg-desktop"
    >
  {% endif %}

  {% if section.settings.mobile_background_image != blank %}
    <img
      src="{{ section.settings.mobile_background_image | image_url: width: 800 }}"
      alt="Mobile Background"
      class="custom-hero-bg-img custom-bg-mobile"
    >
  {% endif %}

  <div class="custom-hero-inner">
    <div class="custom-hero-left">
      <div class="custom-hero-heading">{{ section.settings.heading }}</div>
      <div class="custom-hero-subheading">{{ section.settings.subheading }}</div>
      <div style="display: flex; flex-wrap: wrap;">
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="custom-hero-button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
        {% if section.settings.extra_heading != blank %}
          <div class="custom-hero-small-heading">{{ section.settings.extra_heading }}</div>
        {% endif %}
        {% if section.settings.secondary_button_label != blank %}
          <a href="{{ section.settings.secondary_button_link }}" class="custom-hero-button">
            {{ section.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Image Left Content",
  "settings": [
    {
      "type": "text",
      "id": "extra_heading",
      "label": "Extra Heading (Top Title)",
      "default": "NEW LAUNCH"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Melt ‘n’ Glo"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 20,
      "max": 80,
      "step": 2,
      "default": 36
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A next-gen skin brightening supplement that works from within."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#b4975a"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#b4975a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Button Hover Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_background_image",
      "label": "Mobile Background Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top Padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom Padding",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 40
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "default": "auto",
      "options": [
        { "value": "100vh", "label": "100vh (Full Height)" },
        { "value": "85vh", "label": "85vh" },
        { "value": "70vh", "label": "70vh" },
        { "value": "50vh", "label": "50vh" },
        { "value": "auto", "label": "Auto Height" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Image Left Content",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
