<div class="dr-swiper-container-{{section.id}}   section-{{ section.id }}-padding">
            <h2 class="custom-heading-dr align-{{ section.settings.alignment }}">{{ section.settings.heading }}</h2>
  <br><br><br>
  <div class="dr-swiper dr-swiper-sections">
    <div class="dr-swiper-wrapper container">
      {% for block in section.blocks %}
        <div class="dr-swiper-slide">
        <div class="dr-swiper-slide-img">
          
          <img
            src="{{ block.settings.feature_icon_image | img_url: 'master' }}"
            alt="Feature Icon"
            class="dr-swiper-slide-image-sections"
          >
        </div>
          <div class="text-content-sections">
            <div class="dr-swiper-slide-title-sections">
              <h5 class="dr-swiper-slide-title">
                {{ block.settings.feature_title }}
              </h5>
            </div>
            <div class="dr-swiper-slide-desc">
              {{ block.settings.feature_description_text }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.top_padding | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.bottom_padding | times: 0.75 | round: 0 }}px;
    padding-left: {{ section.settings.left_padding | times: 0.75 | round: 0 }}px;
    padding-right: {{ section.settings.right_padding | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.top_padding }}px;
      padding-bottom: {{ section.settings.bottom_padding }}px;
      padding-left: {{ section.settings.left_padding }}px;
      padding-right: {{ section.settings.right_padding }}px;
    }
  }
{%- endstyle -%}
<style>
  .dr-swiper-container-{{section.id}} {
     background: {{ section.settings.bg_color }};
  }

  .dr-swiper-container   *{
  margin: 0;
  }
  .dr-swiper-container-template--24175769092380__benefits_8xMwKF .custom-heading-dr{
font-weight: 600;
font-size: 45px;
line-height: 120%;
letter-spacing: 3%;
text-align: center;
vertical-align: middle;
text-transform: capitalize;

  }
  h1.custom-heading-dr {
    margin-bottom: 40px;
    font-weight: 700;
    font-size: 45px;
    line-height: 120%;
    letter-spacing: 5%;
    text-align: center;
    vertical-align: middle;
    text-transform: capitalize;
}
  .dr-swiper-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 30px;
  }
  .dr-swiper.dr-swiper-sections {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
}
  .dr-swiper-slide-img {
    height: 102px;
}
.dr-swiper-container-template--24175769092380__benefits_8xMwKF   .dr-swiper-slide-img {
    height: 80px;
}
  .dr-swiper-container-template--24175769092380__benefits_8xMwKF   .dr-swiper-slide-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.dr-swiper-slide {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 20px;
}
.dr-swiper-slide-img img {
    width: 140px;
    height: 100%;
    object-fit: cover;
}
h5.dr-swiper-slide-title {
    font-weight: 600;
    font-size: 30px;
    line-height: 100%;
    letter-spacing: 2%;
    text-align: center;
}
  .dr-swiper-slide-desc p{
  font-size: 14.5px;
  color: #1f1f1f;
  }
  @media screen and (max-width: 1010px) {
  .dr-swiper-wrapper {
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  }
  .dr-swiper-slide-desc {
  text-align: center;
  }
  .dr-swiper-slide-title {
  text-align: center;
  }

  .dr-swiper-slide {
  display: flex;
  justify-content: center;
  flex-direction: column;
  align-items: center;
  /* gap: 20px; */
  }
  }
</style>

{% schema %}
{
  "name": "Benefits",
  "settings": [
  {
          "type": "text",
          "id": "heading",
          "label": "Heading Text"
        },
     {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
     {
      "type": "range",
      "id": "top_padding",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
      "type": "range",
      "id": "bottom_padding",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 92
    },
    {
  "type": "range",
  "id": "left_padding",
  "label": "Left padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
{
  "type": "range",
  "id": "right_padding",
  "label": "Right padding",
  "min": 0,
  "max": 160,
  "step": 2,
  "unit": "px",
  "default": 20
},
       {
        "type": "color",
        "id": "bg_color",
        "label": "Background color",
        "default": "#2A2A2A"
      },
  ],
  "blocks": [
    {
      "type": "feature_block",
      "name": "Guarantee Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "feature_icon_image",
          "label": "Feature Icon Image",
        },
        {
          "type": "text",
          "id": "feature_title",
          "label": "Feature Title",
          "default": "Free Shipping"
        },
        {
          "type": "richtext",
          "id": "feature_description_text",
          "label": "Feature Description",
          "default": "<p>Fast and Reliable Shipping Across the World with No Extra Cost</p>"
        },
        {
          "type": "url",
          "id": "feature_link",
          "label": "Feature Link",
        }
      ]
    }
  ],
  "presets": [
    {
       "name": "Benefits",
    }
  ]
}
{% endschema %}
