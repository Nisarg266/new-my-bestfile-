{% comment %}
  Blog Cards Section - Responsive, accessible grid of blog posts.
  - Header moved outside the grid
  - Responsive images with srcset/sizes + width/height
  - Safe excerpt (strip + truncatewords) and CSS line-clamp
  - Image fallback (placeholder)
  - Optional date/author toggles
  - Focus styles & reduced motion
{% endcomment %}

<style>
  .blog-cards { padding: 20px 20px; }
  .blog-cards .container { max-width: 1200px; margin: 0 auto; }

  .blog-cards__header { text-align: center; margin-bottom: 32px; max-width: 1100px; margin-left: auto; margin-right: auto; }
  .blog-cards__header h2 { margin: 0 0 8px; font-size: 1.875rem; line-height: 1.2; }
  .blog-cards__header p {    font-weight: 400 !important; font-size: 24PX !important; color: #2A2A2A !important ; line-height: 1.5; }

  .blog-cards__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
  }

  .blog-card {
    background: #fff;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-align: left;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .blog-card { transition: none; }
  }



  .blog-card__image { position: relative; aspect-ratio: 4/3; overflow: hidden; }
  .blog-card__image img {
    border-radius:12px;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card__content { padding: 20px; padding-left:0px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
  .blog-card__title { font-size: 1.25rem; font-weight: 700 !important; margin: 0; }
  .blog-card__title a {
    color: #111;
    text-decoration: none;
    line-height: 1.3;
  }
  .blog-card__title a:hover { color: #b98a3e; }

  .blog-card__meta { font-size: 0.875rem; color: #666; }

  .blog-card__excerpt {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-card__button {
    align-self: start;
    display: inline-block;
    background: #b4975a;
    color: #2a2a2a;
    padding: 8px 20px;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500 !important;
    font-size: 23px !important;
    transition: background-color 0.3s ease;
  }
  .blog-card__button:hover { background: #2a2a2a; color:#b4975a }
  .blog-card__button:focus-visible {
    outline: 2px solid #2a2a2a;
    outline-offset: 2px;
  }

  /* Card focus for keyboard users */
  .blog-card a:focus-visible {
    outline: 2px solid #111;
    outline-offset: 2px;
    border-radius: 6px;
  }


   @media (max-width: 768px) {
  .blog-card__button{
  padding: 5px 15px; 
  font-size: 18px !important;
  }
  
  }
</style>

<section class="blog-cards">
  <div class="container">

    <div class="blog-cards__header">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% assign selected_blog = blogs[section.settings.blog] %}

    {% if selected_blog and selected_blog.articles_count > 0 %}
      <div class="blog-cards__grid">
        {% for article in selected_blog.articles limit: section.settings.max_articles %}
          <article class="blog-card" aria-label="{{ article.title | escape }}">
           <a class="blog-card__image" href="{{ article.url }}">
  {% if article.metafields.custom.grid_image != blank %}
    {%- assign widths = "360,540,720,900,1080" | split: "," -%}
    {%- capture srcset -%}
      {%- for w in widths -%}
        {{ article.metafields.custom.grid_image | image_url: width: w | append: " " | append: w | append: "w" }}{% unless forloop.last %}, {% endunless %}
      {%- endfor -%}
    {%- endcapture -%}
    <img
      src="{{ article.metafields.custom.grid_image | image_url: width: 720 }}"
      srcset="{{ srcset }}"
      sizes="(max-width: 600px) 100vw, (max-width: 1200px) 50vw, 360px"
      alt="{{ article.metafields.custom.grid_image.alt | default: article.title | escape }}"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    >
  {% elsif article.image %}
    {%- assign widths = "360,540,720,900,1080" | split: "," -%}
    {%- capture srcset -%}
      {%- for w in widths -%}
        {{ article.image | image_url: width: w | append: " " | append: w | append: "w" }}{% unless forloop.last %}, {% endunless %}
      {%- endfor -%}
    {%- endcapture -%}
    <img
      src="{{ article.image | image_url: width: 720 }}"
      srcset="{{ srcset }}"
      sizes="(max-width: 600px) 100vw, (max-width: 1200px) 50vw, 360px"
      alt="{{ article.image.alt | default: article.title | escape }}"
      loading="lazy"
      decoding="async"
      fetchpriority="low"
    >
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
  {% endif %}
</a>


            <div class="blog-card__content">
              <h3 class="blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>

              {% if section.settings.show_meta %}
                <div class="blog-card__meta">
                  {% if section.settings.show_date %}
                    <time datetime="{{ article.published_at | date: "%Y-%m-%d" }}">
                      {{ article.published_at | date: format: "abbreviated_date" }}
                    </time>
                  {% endif %}
                  {% if section.settings.show_author and article.author %}
                    &nbsp;•&nbsp;{{ article.author }}
                  {% endif %}
                </div>
              {% endif %}

              {% if section.settings.show_excerpt %}
                <p class="blog-card__excerpt">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 28 }}
                </p>
              {% endif %}

              {% if section.settings.button_label != blank %}
                <a href="{{ article.url }}" class="blog-card__button">{{ section.settings.button_label }}</a>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align:center; color:#666;">No articles found. Choose a blog in the section settings.</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Blog Cards (All Articles)",
  "settings": [
    { "type": "blog", "id": "blog", "label": "Choose Blog" },
    {
      "type": "range",
      "id": "max_articles",
      "label": "Maximum number of articles",
      "min": 1, "max": 50, "step": 1, "default": 12
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the blog" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Latest insights and stories" },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show article excerpt", "default": true },
    { "type": "checkbox", "id": "show_meta", "label": "Show meta (date/author)", "default": true },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": false },
    { "type": "text", "id": "button_label", "label": "Button text", "default": "Read more" }
  ],
  "presets": [{ "name": "Blog Cards" }]
}
{% endschema %}
