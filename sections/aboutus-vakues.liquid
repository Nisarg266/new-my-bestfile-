{% comment %}
  Our Values Section
{% endcomment %}

<section id="our-values-{{ section.id }}" class="our-values-section" style="background-color: {{ section.settings.bg_color }};">
  <div class="our-values-container">
    <!-- Heading -->
    <h2 class="our-values-heading" style="color: {{ section.settings.heading_color }};">
      {{ section.settings.heading }}
    </h2>

    <!-- Values Grid -->
   <!-- Desktop Grid -->
<div class="our-values-grid">
  {% for block in section.blocks %}
    <div class="our-value-item">
      <div class="our-value-icon" style="background-color: {{ block.settings.icon_bg }}">
        {% if block.settings.icon != blank %}
          <img src="{{ block.settings.icon | img_url: '100x100' }}" alt="{{ block.settings.title }}">
        {% endif %}
      </div>
      <p class="our-value-text" style="color: {{ section.settings.text_color }};">
        {{ block.settings.title }}
      </p>
    </div>
  {% endfor %}
</div>

<!-- Mobile Marquee -->
<!-- Mobile Marquee -->
<div class="our-values-marquee">
  <div class="our-values-marquee-track">
    {% for i in (1..7) %}
      {% for block in section.blocks %}
        <div class="our-value-item">
          <div class="our-value-icon" style="background-color: {{ block.settings.icon_bg }}">
            {% if block.settings.icon != blank %}
              <img src="{{ block.settings.icon | img_url: '100x100' }}" alt="{{ block.settings.title }}">
            {% endif %}
          </div>
          <p class="our-value-text" style="color: {{ section.settings.text_color }};">
            {{ block.settings.title }}
          </p>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</div>


  </div>
</section>
<style>
  .our-values-section {
    padding: 60px 20px;
  }

  .our-values-container {
    max-width: 1300px;
    margin: 0 auto;
    text-align: center;
  }

  .our-values-heading {
    font-size: clamp(28px, 5vw, 50px)!important;
    font-weight: 700;
    margin-bottom: 50px;
  }

  /* Desktop grid */
  .our-values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 35px;
    align-items: center;
    justify-content: center;
  }

 /* Mobile grid (2x2 full width) */
/* Default desktop grid */
.our-values-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 35px;
  align-items: center;
  justify-content: center;
}

/* Hide marquee on desktop */
.our-values-marquee {
  display: none;
}

/* Mobile styles: show marquee, hide grid */
@media (max-width: 767px) {
  .our-values-grid {
    display: none;
  }

  .our-values-marquee {
    display: flex;
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .our-values-marquee-track {
    display: flex;
    gap: 30px;
    animation: scroll-marquee 30s linear infinite; /* slower speed */
  }

  .our-value-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: max-content;
  }

  .our-value-icon {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .our-value-icon img {
      width: 55px;
    height: 55px;
    object-fit: contain;
  }

  .our-value-text {
    font-size: 14px !important;
    white-space: nowrap;
  }

  @keyframes scroll-marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-25%); } /* since duplicated 4× */
  }
}


  /* Each item: icon + text side by side */
  .our-value-item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: left;
  }

  .our-value-icon {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .our-value-icon img {
      width: 55px;
    height: 55px;
    object-fit: contain;
  }

  .our-value-text {
    color:#2a2a2a !important;
    font-size: 20px !important;
    font-weight: 500;
  }
</style>


{% schema %}
{
  "name": "Core Values",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR VALUES"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f1efec"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#b4975a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Core Value",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Value Text",
          "default": "Holistic Health"
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Icon Background Color",
          "default": "#b4975a"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Core Values",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}
