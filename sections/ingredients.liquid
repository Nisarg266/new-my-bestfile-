        {% endfor %}
      </div>
    </div>
  </div>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css" />

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = '{{ section.id }}';
    const swiperSelector = `.ma-ingredients-swiper-${sectionId}`;
    const swiperContainer = document.querySelector(swiperSelector);

    if (!swiperContainer || swiperContainer.classList.contains('swiper-initialized')) return;

    swiperContainer.classList.add('swiper-initialized');

    // Add slide class (for safety)
    const wrapper = swiperContainer.querySelector('.swiper-wrapper');
    if (wrapper) {
      const slides = wrapper.children;
      Array.from(slides).forEach(slide => slide.classList.add('swiper-slide'));
    }

    // Force breakpoint init using `modules` logic
    let swiperInstance;

    function initSwiper() {
      swiperInstance = new Swiper(swiperSelector, {
        loop: false,
        spaceBetween: 15,
        slidesPerView: 1,
        navigation: {
          nextEl: `.swiper-button-next-${sectionId}`,
          prevEl: `.swiper-button-prev-${sectionId}`
        },
        breakpoints: {
          0: {
            slidesPerView: 1,
            allowTouchMove: true,
            enabled: true
          },
          769: {
            slidesPerView: 1,
            allowTouchMove: false,
            enabled: false
          }
        }
      });
    }

    // Load Swiper script if not loaded yet
    if (window.Swiper) {
      initSwiper();
    } else {
      const script = document.createElement('script');
      script.src = "https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js";
      script.onload = initSwiper;
      document.head.appendChild(script);
      
    }
  });
</script>



{% endif %}


