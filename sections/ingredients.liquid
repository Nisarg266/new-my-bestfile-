      }
    }
  </style>

  <div class="clinical-ingredients-{{ section.id }} color-{{ section.settings.color_scheme }} gradient js-animation-fade-in section-{{ section.id }}-padding">
    <div class="container-ingredients">
      {% if section.settings.heading_line1 != blank or section.settings.heading_line2 != blank %}
        <h2 class="section__heading">
          {{ section.settings.heading_line1 }}
          {% if section.settings.heading_line2 != blank %}
            <br>{{ section.settings.heading_line2 }}
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.showslider_mobile %}
        <div class="swiper ma-ingredients-swiper-{{ section.id }} d-block d-md-none">
          <div class="swiper-wrapper">
            {% for block in section.blocks %}
              <div class="ingredient-item-{{ section.id }} swiper-slide" {{ block.shopify_attributes }}>
                {% if block.settings.image %}
                  <div class="ingredient-img-{{ section.id }}">
                    <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
                  </div>
                {% endif %}
                <div class="ingredient-text-{{ section.id }}">
                  <h3 class="ingredient-title-{{ section.id }}">{{ block.settings.heading }}</h3>
                  <p class="ingredient-description-{{ section.id }}">{{ block.settings.text }}</p>
                  {% if block.settings.button_text and block.settings.button_link %}
  <a href="{{ block.settings.button_link }}" class="ingredient-button-{{ section.id }}">
    <span class="arrow-circle">
      <svg fill="#000000" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
        <path d="M5.975 17.504l14.287.001-6.367 6.366L16.021 26l10.004-10.003L16.029 6l-2.128 2.129 6.367 6.366H5.977z"></path>
      </svg>
    </span>
    {{ block.settings.button_text }}
  </a>
{% endif %}
                </div>
              </div>
            {% endfor %}
          </div>

          {% if section.settings.pagination %}
            <div class="swiper-button-prev-{{ section.id }} custom-swiper-arrow-{{ section.id }}">
              <!-- Prev Arrow SVG -->
              <svg xmlns="http://www.w3.org/2000/svg" width="7" height="12"><path d="M0.285376 10.7726C0.0408089 11.0167 0.0463463 11.4079 0.298297 11.6457C0.549324 11.8835 0.951706 11.8782 1.19627 11.6332L6.09869 6.71646L5.64371 6.28662L6.10054 6.71736C6.34511 6.47148 6.33957 6.07933 6.0867 5.84152L1.19535 0.981335C0.950784 0.736351 0.549324 0.730967 0.297374 0.968772C0.0463463 1.20658 0.0408089 1.59693 0.285376 1.84192L4.75773 6.28841L0.285376 10.7726Z" fill="white"/></svg>
            </div>
            <div class="swiper-button-next-{{ section.id }} custom-swiper-arrow-{{ section.id }}">
              <!-- Next Arrow SVG -->
              <svg xmlns="http://www.w3.org/2000/svg" width="7" height="12"><path d="M0.285376 10.7726C0.0408089 11.0167 0.0463463 11.4079 0.298297 11.6457C0.549324 11.8835 0.951706 11.8782 1.19627 11.6332L6.09869 6.71646L5.64371 6.28662L6.10054 6.71736C6.34511 6.47148 6.33957 6.07933 6.0867 5.84152L1.19535 0.981335C0.950784 0.736351 0.549324 0.730967 0.297374 0.968772C0.0463463 1.20658 0.0408089 1.59693 0.285376 1.84192L4.75773 6.28841L0.285376 10.7726Z" fill="white"/></svg>
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ingredients__grid-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="ingredient-item-{{ section.id }}" {{ block.shopify_attributes }}>
            {% if block.settings.image %}
              <div class="ingredient-img-{{ section.id }}">
                <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.heading | escape }}" loading="lazy">
              </div>
            {% endif %}
            <div class="ingredient-text-{{ section.id }}">
              <h3 class="ingredient-title-{{ section.id }}">{{ block.settings.heading }}</h3>
              <p class="ingredient-description-{{ section.id }}">{{ block.settings.text }}</p>
              
            </div>

            <div class = "read-more-v">
              {% if block.settings.button_text and block.settings.button_link %}
<a href="{{ block.settings.button_link }}" class="ingredient-button-{{ section.id }}">
  <span class="arrow-circle">
   <svg fill="#000000" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M5.975 17.504l14.287.001-6.367 6.366L16.021 26l10.004-10.003L16.029 6l-2.128 2.129 6.367 6.366H5.977z"></path></g></svg>
  </span>
  {{ block.settings.button_text }}
</a>

              {% endif %}
