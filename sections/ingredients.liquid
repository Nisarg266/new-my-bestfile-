{% if section.blocks.size > 0 %}
  <style>
    .clinical-ingredients-{{ section.id }} {
      background: {{ section.settings.background_color }};
      padding: 60px 0;
      text-align: center;
    }

    .container-ingredients {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 20px;
    }

    .clinical-ingredients-{{ section.id }} .section__heading {
      font-size: clamp(30px, 5vw, 50px) !important;
      text-transform:Uppercase;
      font-weight: 700;
      margin-bottom: 50px;
      color: #b4975a;
      text-align: center;
    }

    .ingredients__grid-{{ section.id }} {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      width: 100%;
      max-width: 1600px;
      margin: 0 auto;
    }

    .ingredient-item-{{ section.id }} {
      background:#ECE9E6;
      border-radius: 16px;
      padding: 40px 30px;
      text-align: left;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }

    .ingredient-item-{{ section.id }}:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }

    .ingredient-img-{{ section.id }} {
        position: absolute;
    top: 0px;
    right: -14px;
    width: 50%;
    height: 100%;
    }

    .ingredient-img-{{ section.id }} img {
      width: 100%;
      height: 100%;
      object-fit: cover ;
    }

    .ingredient-title-{{ section.id }} {
font-size: clamp(20px, 5vw, 30px) !important;
      font-weight: 700;
      line-height: 1.3;
      color: #231f20;

    }

    .ingredient-description-{{ section.id }} {
      font-size: 16px;
      font-weight: 400;
      line-height: 1.6;
      color: #666;
    margin-bottom: 60px;      flex-grow: 1;
    }

    .ingredient-button-{{ section.id }} {
      font-weight: 600;
      font-size: 14px;
      color: rgb(0, 0, 0);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: all 0.3s ease;
      position: relative;
    }
.read-more-v{
padding-left:20px;
}
  .ingredient-button-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 10px; /* space between arrow circle and text */
  font-weight: 600;
  font-size: 14px;
  color: #b4975a; /* gold text */
  text-decoration: none;
  transition: all 0.3s ease;
}

/* Remove the existing after arrow */
.ingredient-button-{{ section.id }}::after {
  content: none !important;
}

/* Circle around arrow */
.ingredient-button-{{ section.id }} .arrow-circle {
  background-color: #2a2a2a;
  border-radius: 50%;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Arrow inside circle */
.ingredient-button-{{ section.id }} .arrow-circle svg {
  width: 12px;
  height: 12px;
  stroke: white;
  fill: none;
  stroke-width: 2;
}


    .ingredient-text-{{ section.id }} {
      padding:60px 20px;
      padding-bottom:0px;
      width:50%;
      display: flex;
      flex-direction: column;
      flex: 1;padding-bottom: 0px;
width: 50%;
display: flex;
flex-direction: column;
flex: 1;
justify-content: center;  /* vertical centering */
    }

    .custom-swiper-arrow-{{ section.id }} {
      width: 48px;
      height: 48px;
      background-color:rgb(0, 0, 0);
      border-radius: 50%;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 11;
      display: flex !important;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .swiper-button-prev-{{ section.id }} {
      left: 10px;
    }

    .swiper-button-next-{{ section.id }} {
      right: 10px;
    }

    .swiper-button-prev-{{ section.id }} svg {
      transform: rotate(180deg);
    }

    .swiper-button-prev-{{ section.id }}::after,
    .swiper-button-next-{{ section.id }}::after {
      display: none;
    }
/* Arrow animation inside ingredient buttons */
.ingredient-button-{{ section.id }} .arrow-circle svg {
  transition: transform 0.4s ease-in-out, opacity 0.4s ease-in-out;
}

.ingredient-item-{{ section.id }}:hover .ingredient-button-{{ section.id }} .arrow-circle svg {
  animation: arrow-loop-{{ section.id }} 0.6s ease-in-out forwards;
}

@keyframes arrow-loop-{{ section.id }} {
  0% {
    transform: translateX(0);
    opacity: 1;
  }
  40% {
    transform: translateX(8px);
    opacity: 0;
  }
  41% {
    transform: translateX(-8px);
    opacity: 0;
  }
  100% {
    transform: translateX(0);
    opacity: 1;
  }
}

    /* Tablet Styles */
