{% schema %}
{
  "name": "Fuel From Inside",
  "tag": "section",
  "class": "fuel-from-inside",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "FUEL THE BEST VERSION OF YOU–FROM THE INSIDE OUT."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Powerhouse ingredients. Real Results. Wellness that works– for the life you’re building."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Experience it now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ]
}
{% endschema %}

{% style %}
.fuel-from-inside-wrapper {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 80px 30px;
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  color: #000;
  min-height: 500px;
}

.fuel-from-inside-content {
  max-width: 600px;
  background: rgba(255, 255, 255, 0.8); /* optional for readability on mobile */
  padding: 20px;
}

.fuel-from-inside-content h2 {
  font-size: 2.5rem;
  font-weight: bold;
  margin-bottom: 20px;
}

.fuel-from-inside-content p {
  font-size: 1.2rem;
  margin-bottom: 30px;
}

.fuel-from-inside-content a {
  display: inline-block;
  background: #000;
  color: #fff;
  padding: 12px 24px;
  text-decoration: none;
  font-weight: 600;
  transition: background 0.3s;
}

.fuel-from-inside-content a:hover {
  background: #333;
}

/* Mobile responsiveness */
@media screen and (max-width: 768px) {
  .fuel-from-inside-wrapper {
    padding: 60px 20px;
    justify-content: center;
    text-align: center;
    background-image: url('{{ section.settings.background_image_mobile | img_url: "master" }}') !important;
  }

  .fuel-from-inside-content {
    background: rgba(255, 255, 255, 0.85); /* Optional overlay */
    padding: 20px;
    border-radius: 10px;
  }
}
{% endstyle %}

<div
  class="fuel-from-inside-wrapper"
  style="background-image: url('{{ section.settings.background_image_desktop | img_url: "master" }}');"
>
  <div class="fuel-from-inside-content">
    <h2>{{ section.settings.main_heading }}</h2>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
    {% endif %}
  </div>
</div>
